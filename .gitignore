### Go template
# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Logs and local diagnostics
*.log
/.expert/

# Root-only scratch programs and one-off operational experiments
/sim*.go
/test_*.go
/get_keys
/get_keys.go
/synthsend-linux
/change_pass.exp
/monkey_test.sh
/fix-kubelet.yaml
/patch.yaml
/test-*.yaml

# Console one-off diagnostics; maintained tests use *.test.ts
/console/test-*.ts
/console/admin/test-*.ts


.idea/

# macOS
.DS_Store

# Certificates and keys
*.pem
*.key
*.p12
*.pfx
*.keystore

# Compiled binaries (root level)
/broadcaster-data

# Elixir build artifacts
_build/
deps/
*.ez

# Kubernetes deployments are fully tracked and Flux-managed. No plaintext
# secrets live here: every credential comes from a Doppler-managed Secret
# referenced by name, and the nats *.conf files carry only $ENV placeholders
# that nats-server expands from the nats-auth-env secret at runtime.
deploy_backup/

# macOS Finder cruft
.DS_Store

# Exclude scratch, claude, and tar files
.claude/
scratch/
*.tar
*.tar.gz

# Local build artifacts and dev tooling (never committed)
bustest
*_bin
**/tmp/
.air.toml

# Root scratch / experiments (not part of any service build)
/check.go
/scratch.go
/scratch2.go
/test_csrf.go
/test_csrf2.go
/test_csrf3.go
/test_js.go
/test_templ.templ
/test_templ2.go
/test_templ_templ.go
/test_htmx.html
/test-env.yaml
