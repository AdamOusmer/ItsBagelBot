# Dashboard SSR — separate deploy from admin. Build with bun, run on distroless
# Node (adapter-node output). Native per-node build (ARM on node1, Intel on
# node2); no cross-arch emulation.
FROM docker.io/oven/bun:1.3.10 AS build
WORKDIR /src
# Pin SvelteKit's build version to the commit SHA so the ARM and Intel native
# builds emit IDENTICAL hashed asset names. Otherwise version defaults to a
# per-build timestamp, the two arches diverge, and a stateless LB serves HTML
# from one arch with chunk 404s from the other.
ARG BUILD_VERSION=dev
ENV BUILD_VERSION=$BUILD_VERSION
# Workspace manifests first for cached installs. bunfig.toml MUST be present for
# the install so the hoisted linker applies (flat node_modules the image can ship).
COPY package.json bun.lock bunfig.toml ./
COPY adapter-node-fixed.js adapter-node-fixed.js
COPY shared/package.json shared/package.json
COPY dashboard/package.json dashboard/package.json
COPY admin/package.json admin/package.json
RUN bun install --frozen-lockfile
COPY shared shared
COPY dashboard dashboard
RUN cd dashboard && bun run build && bun install --production --frozen-lockfile

FROM gcr.io/distroless/nodejs22-debian12 AS run
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
# adapter-node bundle + external production deps
COPY --from=build /src/dashboard/build ./build
COPY --from=build /src/node_modules ./node_modules
EXPOSE 3000
# Preload the New Relic APM agent (ESM --import) before the SvelteKit server.
CMD ["--import", "newrelic", "build/index.js"]
