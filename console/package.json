{
  "name": "console",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": ["shared", "dashboard", "admin"],
  "scripts": {
    "build": "bun run --filter dashboard build && bun run --filter admin build",
    "dev:dashboard": "bun run --filter dashboard dev",
    "dev:admin": "bun run --filter admin dev",
    "check": "bun run --filter '*' check",
    "test": "bun test shared"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "mysql2": "^3.22.5",
    "sirv": "^3.0.2"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "@opentelemetry/core": "^2.8.0",
    "cookie": "^0.7.0"
  }
}
