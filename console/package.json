{
  "name": "console",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": ["shared", "dashboard", "admin"],
  "scripts": {
    "build": "bun run --filter dashboard build && bun run --filter admin build",
    "dev:dashboard": "bun run --filter dashboard dev",
    "dev:admin": "bun run --filter admin dev",
    "check": "bun run --filter '*' check",
    "test": "bun test shared"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@sveltejs/adapter-node": "^5.5.5",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  },
  "dependencies": {
    "mysql2": "^3.22.5",
    "sirv": "^3.0.2"
  }
}
