{
  "name": "console",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": ["shared", "dashboard", "admin"],
  "scripts": {
    "build": "bun run --filter dashboard build && bun run --filter admin build",
    "dev:dashboard": "bun run --filter dashboard dev",
    "dev:admin": "bun run --filter admin dev",
    "check": "bun run --filter '*' check"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.17.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
