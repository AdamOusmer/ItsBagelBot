# Admin SSR — separate deploy from dashboard. Build with bun, run on distroless
# Node (adapter-node output). Native per-node build (ARM/Intel); no emulation.
FROM docker.io/oven/bun:1.3.10 AS build
WORKDIR /src
# Pin SvelteKit's version metadata to the commit SHA. sorted-readdir.mjs also
# makes route-node assignment deterministic across the native ARM/Intel builds.
ARG BUILD_VERSION=dev
ENV BUILD_VERSION=$BUILD_VERSION
# bunfig.toml MUST be present so the hoisted linker applies (flat node_modules).
COPY package.json bun.lock bunfig.toml ./
COPY tsconfig.base.json tsconfig.base.json
COPY sorted-readdir.mjs sorted-readdir.mjs
COPY shared/package.json shared/package.json
COPY dashboard/package.json dashboard/package.json
COPY admin/package.json admin/package.json
RUN bun install --frozen-lockfile
COPY shared shared
COPY admin admin
# `bun run build` also scans the final adapter-node output and fails if any
# development identity or seeded demo fixture was emitted into the image.
RUN cd admin && bun run build && bun install --production --frozen-lockfile

FROM gcr.io/distroless/nodejs22-debian12 AS run
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
COPY --from=build /src/admin/build ./build
COPY --from=build /src/node_modules ./node_modules
COPY serve-node.js ./serve-node.js
EXPOSE 3000
# Preload the New Relic APM agent (ESM --import) before the SvelteKit server.
CMD ["--import", "newrelic", "serve-node.js"]
