#!/usr/bin/env bash
# Wrapper around adr-tools that points it at the project-local template
# and post-processes `adr new` output so the frontmatter title uses the
# zero-padded NNNN format (matching the filename), instead of the raw
# unpadded number adr-tools substitutes for the `NUMBER` placeholder.
# Run from anywhere — the script resolves paths relative to the docs/ root.
set -euo pipefail

project_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

export ADR_TEMPLATE="$project_root/.adr/template.md"

cd "$project_root"

if [ "${1:-}" = "new" ]; then
    shift
    # adr new prints the created file path on its final line of stdout.
    file=$(adr new "$@" | tail -n 1)
    num=$(basename "$file" | grep -oE '^[0-9]+')
    # Replace the leading unpadded number in `title: "<n> - …"` with the
    # 4-digit padded version pulled from the filename.
    sed -i '' -E "s/^title: \"[0-9]+ - (.*)\"\$/title: \"$num - \\1\"/" "$file"
    echo "$file"
else
    exec adr "$@"
fi
