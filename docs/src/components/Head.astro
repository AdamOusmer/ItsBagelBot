---
import Default from '@astrojs/starlight/components/Head.astro';
import { ClientRouter } from 'astro:transitions';
import SmoothScroll from './SmoothScroll.astro';
import SidebarState from './SidebarState.astro';
import MermaidStyles from './MermaidStyles.astro';
import MermaidInteractive from './MermaidInteractive.astro';

// Social meta. With `site` configured, Starlight already emits:
//   canonical, og:title/type/url/locale/description/site_name, twitter:card.
// We fill the gaps — share-card image and the twitter:title/desc/image
// trio that Slack and a few legacy clients don't infer from og:*.
const ogImage = new URL('/og-image.png', Astro.site).href;
const { entry } = Astro.locals.starlightRoute ?? {};
const pageTitle = entry?.data.title ?? 'ItsBagelBot Docs';
const pageDescription = entry?.data.description
  ?? 'The all-in-one Twitch companion baked for independence.';

// Structured data. @id values point at the marketing origin so search engines
// merge this Organization with the one on itsbagelbot.com (one entity across
// subdomains); the WebSite entity is the docs site itself.
const MAIN = 'https://itsbagelbot.com';
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${MAIN}/#organization`,
      name: 'ItsBagelBot',
      url: `${MAIN}/`,
      logo: `${MAIN}/android-chrome-512x512.png`,
      sameAs: [
        'https://twitch.tv/itsbagelbot',
        'https://discord.gg/SZ2remwSDv',
        'https://github.com/AdamOusmer/ItsBagelBot',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': new URL('/#website', Astro.site).href,
      url: new URL('/', Astro.site).href,
      name: 'ItsBagelBot Docs',
      description: 'Guides, architecture, and reference for the all-in-one Twitch companion.',
      inLanguage: 'en',
      publisher: { '@id': `${MAIN}/#organization` },
    },
  ],
};
---

<Default><slot /></Default>

{/* Share-card image + twitter:* fallbacks. */}
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="ItsBagelBot Docs" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDescription} />
<meta name="twitter:image" content={ogImage} />

{/* Favicon set — files live in /public and are served from the site root. */}
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

{/* Browser-chrome tint. Matches the docs page bg per theme so the
    mobile address bar blends rather than clashes with the layout. */}
<meta name="theme-color" media="(prefers-color-scheme: dark)"  content="#0a0a0a" />
<meta name="theme-color" media="(prefers-color-scheme: light)" content="#faf5e9" />

{/* Robots: index + follow by default. Override per page via frontmatter. */}
<meta name="robots" content="index, follow, max-image-preview:large" />

{/* Structured data — Organization (merged with the marketing site) + this docs site. */}
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />

{/* Preconnect to Google Fonts so the @import in theme.css gets its
    DNS + TLS warmed before the CSS parser hits the URL. */}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<ClientRouter />
<SmoothScroll />
<SidebarState />
<MermaidStyles />
<MermaidInteractive />
