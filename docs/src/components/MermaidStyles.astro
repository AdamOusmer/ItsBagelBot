---
---
<style is:global>
/* ════════════════════════════════════════════════════════════════════
   Mermaid diagrams — astro-mermaid emits `<pre class="mermaid">`, then
   replaces its contents with an `<svg>` after client-side render. We
   style both the pre wrapper and the rendered SVG.

   Readability rules:
   • DARK MODE  — light tan/cream nodes on a dark panel.
   • LIGHT MODE — same tan nodes (baked by Mermaid from themeVariables)
     on a cream panel; ALL edges, arrows, and floating text must flip
     to dark ink so they're visible against the light surface.
   ════════════════════════════════════════════════════════════════════ */

/* The rendered (post-render) state. astro-mermaid adds
   data-processed="true" once the SVG is in place.

   Container goals:
   - Generous internal padding so the SVG never crowds the border
   - Solid darker fill so light tan nodes pop against it
   - Horizontal scroll when the native-size SVG exceeds column width
   - Subtle inset glow so the box reads as "a panel" not "a card" */
pre.mermaid[data-processed] {
    display: block;
    margin: 2rem 0;
    width: 100%;
    max-width: 100%;
    position: relative;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 2.5vw, 2rem);
    border: 1px solid rgb(var(--bb-green-glow-rgb) / 0.22) !important;
    border-radius: 14px;
    background:
        radial-gradient(
            120% 100% at 0% 0%,
            rgb(var(--bb-green-rgb) / 0.08),
            transparent 60%
        ),
        radial-gradient(
            120% 100% at 100% 100%,
            rgb(var(--bb-tan-rgb) / 0.05),
            transparent 60%
        ),
        var(--bb-mermaid-panel) !important;
    box-shadow:
        inset 0 1px 0 rgb(var(--bb-white-pure-rgb) / 0.03),
        0 1px 0 rgb(var(--bb-shadow-rgb) / 0.4);
    overflow-x: auto;
    overflow-y: hidden;
    text-align: center;
    line-height: 1;
    color: var(--bb-white);
    scrollbar-color: var(--bb-border-strong) transparent;
}

pre.mermaid[data-processed]::-webkit-scrollbar {
    height: 8px;
}

pre.mermaid[data-processed]::-webkit-scrollbar-thumb {
    background: var(--bb-border-strong);
    border-radius: 999px;
}

/* Pre-render skeleton — while mermaid.js loads + parses, the raw
   source is briefly visible. Fade it so it doesn't flash as bright
   plain text on dark backgrounds. */
pre.mermaid:not([data-processed]) {
    display: block;
    margin: 1.5rem 0;
    padding: 1.25rem;
    border: 1px solid rgb(var(--bb-green-glow-rgb) / 0.12);
    border-radius: 12px;
    background: var(--bb-card-bg);
    color: var(--bb-muted);
    font-family: var(--bb-font-mono);
    font-size: 0.78rem;
    white-space: pre-wrap;
    opacity: 0.55;
    min-height: 6rem;
}

/* Native-size SVG with crisp rendering hints. */
pre.mermaid svg {
    height: auto;
    margin: 0 auto;
    display: inline-block;
    shape-rendering: geometricPrecision;
    text-rendering: geometricPrecision;
    /* Subtle ambient lift — not so heavy that it muddies node edges */
    filter: drop-shadow(0 4px 12px rgb(var(--bb-shadow-rgb) / 0.30));
}

/* ── Edges / arrows ────────────────────────────────────────────────
   Heavier strokes so direction reads from across the room. Targets
   every edge selector Mermaid emits across diagram types. */
pre.mermaid svg .edgePath .path,
pre.mermaid svg .flowchart-link,
pre.mermaid svg path.relation,
pre.mermaid svg .messageLine0,
pre.mermaid svg .messageLine1,
pre.mermaid svg line.messageLine0,
pre.mermaid svg line.messageLine1,
pre.mermaid svg .transition {
    stroke-width: 2.5px !important;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none !important;
}

/* The vertical lifelines under sequence actors — keep them quieter
   than message arrows so the messages dominate. */
pre.mermaid svg .actor-line {
    stroke-width: 1.5px !important;
    stroke-dasharray: 0;
    opacity: 0.55;
}

/* Arrowhead markers — match the new heavier shafts. */
pre.mermaid svg marker path,
pre.mermaid svg #arrowhead path,
pre.mermaid svg .arrowheadPath,
pre.mermaid svg .marker {
    stroke-width: 1.5px !important;
    stroke: var(--bb-tan-light);
    fill: var(--bb-tan-light);
}

/* ── Edge labels — solid pill + text halo for max readability ──────
   The pill is --bb-elev-2 (#1d1a14) — dark enough to anchor the
   label but visibly lighter than the panel bg (#0d0c0a). */
pre.mermaid svg .edgeLabel {
    background-color: transparent !important;
}

pre.mermaid svg .edgeLabel rect {
    fill: var(--bb-elev-2) !important;
    stroke: rgb(var(--bb-tan-rgb) / 0.35) !important;
    stroke-width: 1px !important;
    rx: 6;
    ry: 6;
}

pre.mermaid svg .edgeLabel foreignObject > div {
    background-color: var(--bb-elev-2) !important;
}

pre.mermaid svg [class*="edgeLabel"] text,
pre.mermaid svg [class*="edgeLabel"] tspan,
pre.mermaid svg [class*="edgeLabel"] span,
pre.mermaid svg [class*="edgeLabel"] p,
pre.mermaid svg .edgeLabel text,
pre.mermaid svg .edgeLabel tspan,
pre.mermaid svg .edgeLabel span,
pre.mermaid svg .edgeLabel p {
    background-color: transparent !important;
    color: var(--bb-tan-pale) !important;
    fill: var(--bb-tan-pale) !important;
    border: none !important;
    line-height: 1.2 !important;
}

/* SVG-text edge labels (Mermaid uses these when htmlLabels are off,
   or for state diagrams). Dark stroke + light fill via paint-order
   creates a halo so the label is readable wherever it lands. */
pre.mermaid svg .edgeLabel text,
pre.mermaid svg .edgeLabel text tspan,
pre.mermaid svg g.edgeLabel text,
pre.mermaid svg g.edgeLabel text tspan {
    fill: var(--bb-tan-pale) !important;
    paint-order: stroke fill;
    stroke: var(--bb-card-bg);
    stroke-width: 4px;
    stroke-linejoin: round;
}

/* ── Nodes — sticky-note feel ────────────────────────────────────── */
pre.mermaid svg .node rect,
pre.mermaid svg .node circle,
pre.mermaid svg .node ellipse,
pre.mermaid svg .node polygon,
pre.mermaid svg .node path {
    stroke-width: 2px !important;
    rx: 8;
    ry: 8;
}

/* Node label text — semi-bold, sans, dark on the tan fills.
   Two paths to cover here:
   1. HTML labels (default): Mermaid wraps text in <foreignObject>
      with a div.nodeLabel. CSS `color` controls this.
   2. SVG text labels (cylinder, circle, diamond shapes — and what
      Mermaid falls back to when htmlLabels is off): plain SVG
      <text>/<tspan>. CSS `color` is inert on SVG text; we need
      `fill` instead.
   Both paths force the same dark color so every shape reads the
   same regardless of which renderer Mermaid picked for it. */
pre.mermaid svg .nodeLabel,
pre.mermaid svg .nodeLabel p,
pre.mermaid svg .nodeLabel span,
pre.mermaid svg .node foreignObject div,
pre.mermaid svg .node foreignObject p,
pre.mermaid svg .node foreignObject span {
    color: var(--bb-ink) !important;
    line-height: 1.25 !important;
}

/* SVG-native text inside any node — fill, not color. */
pre.mermaid svg .node text,
pre.mermaid svg .node text tspan,
pre.mermaid svg g.node text,
pre.mermaid svg g.node text tspan,
pre.mermaid svg .nodeLabel text,
pre.mermaid svg .nodeLabel tspan {
    fill: var(--bb-ink) !important;
}

/* ── Sequence diagram — actors styled like primary nodes ─────────── */
pre.mermaid svg .actor {
    stroke-width: 2px !important;
    rx: 8;
    ry: 8;
}

pre.mermaid svg .actor text,
pre.mermaid svg text.actor > tspan {
    fill: var(--bb-ink) !important;
}

pre.mermaid svg .messageText {
    fill: var(--bb-white) !important;
}

pre.mermaid svg .labelText,
pre.mermaid svg .labelText tspan,
pre.mermaid svg .loopText,
pre.mermaid svg .loopText tspan {
}

pre.mermaid svg .noteText,
pre.mermaid svg .noteText tspan {
    fill: var(--bb-tan-pale) !important;
}

/* Loop/alt/opt boxes around grouped messages — quieter outline. */
pre.mermaid svg .labelBox {
    stroke-width: 1.5px !important;
    rx: 4;
    ry: 4;
}

/* ── Clusters / subgraphs — soft-edged grouping ──────────────────── */
pre.mermaid svg .cluster rect {
    rx: 14 !important;
    ry: 14 !important;
    stroke-dasharray: 5 5;
    stroke-width: 1.5px;
    fill: rgba(82, 183, 136, 0.10) !important;
    stroke: rgba(82, 183, 136, 0.50) !important;
}

/* Cluster / subgraph labels — nuclear approach to target EVERYTHING
   inside a cluster wrapper. */
pre.mermaid svg [class*="cluster"] text,
pre.mermaid svg [class*="cluster"] tspan,
pre.mermaid svg [class*="cluster"] span,
pre.mermaid svg [class*="cluster"] p,
pre.mermaid svg [class*="cluster"] div,
pre.mermaid svg .cluster text,
pre.mermaid svg .cluster tspan,
pre.mermaid svg .cluster span,
pre.mermaid svg .cluster p,
pre.mermaid svg .cluster div,
pre.mermaid svg .cluster .nodeLabel {
    color: var(--bb-green-glow) !important;
    fill: var(--bb-green-glow) !important;
}

/* ── Diagram title — .titleText ──────────────────────────────────
   Mermaid renders `---\ntitle: Foo\n---` as a <text class="titleText">.
   themeVariables.titleColor bakes as #f0ece4 (light) which is fine
   on dark but invisible on light — CSS handles the flip. */
pre.mermaid svg .titleText,
pre.mermaid svg .titleText tspan {
    fill: var(--bb-white) !important;
}

/* ── Generic / fallback text selectors ───────────────────────────
   Mermaid emits text under many different class names depending on
   diagram type. These catch-all selectors ensure nothing renders as
   invisible white-on-white or dark-on-dark. */
pre.mermaid svg .label text,
pre.mermaid svg .label tspan,
pre.mermaid svg .label foreignObject > div,
pre.mermaid svg .label foreignObject > div > span {
}

/* State diagrams — state names */
pre.mermaid svg .statediagram-state .nodeLabel,
pre.mermaid svg .state-note-text,
pre.mermaid svg .stateLabel text,
pre.mermaid svg .stateLabel tspan {
    fill: var(--bb-ink) !important;
    color: var(--bb-ink) !important;
}

/* ER diagrams — entity and relationship labels */
pre.mermaid svg .entityLabel,
pre.mermaid svg .entityLabel tspan,
pre.mermaid svg .relationshipLabel,
pre.mermaid svg .relationshipLabel tspan {
    fill: var(--bb-ink) !important;
}


/* ════════════════════════════════════════════════════════════════════
   LIGHT MODE — unified overrides for ALL diagram types.

   The mermaidDarkVars bake tan fills / light text into the SVG at
   build time. In light mode the panel flips to cream, so every
   "floating" element (edges, arrows, markers, labels) that was
   designed for dark-on-light must now become dark-on-light too.
   ════════════════════════════════════════════════════════════════════ */

/* Panel container */
:root[data-theme="light"] pre.mermaid[data-processed] {
    border-color: rgb(var(--bb-green-rgb) / 0.25) !important;
    background:
        radial-gradient(
            120% 100% at 0% 0%,
            rgb(var(--bb-green-rgb) / 0.06),
            transparent 60%
        ),
        radial-gradient(
            120% 100% at 100% 100%,
            rgb(var(--bb-tan-deep-rgb) / 0.05),
            transparent 60%
        ),
        var(--bb-paper) !important;
    color: var(--bb-ink);
    box-shadow:
        inset 0 1px 0 rgb(var(--bb-white-pure-rgb) / 0.6),
        0 1px 2px rgb(var(--bb-ink-rgb) / 0.08);
}

:root[data-theme="light"] pre.mermaid:not([data-processed]) {
    background: var(--bb-paper);
    color: var(--bb-ink-mid);
    border-color: rgb(var(--bb-green-rgb) / 0.18);
}

/* SVG shadow — lighter on cream so it doesn't look muddy */
:root[data-theme="light"] pre.mermaid svg {
    filter: drop-shadow(0 2px 8px rgb(var(--bb-ink-rgb) / 0.10));
}

/* ── Light: diagram title ─────────────────────────────────────── */
:root[data-theme="light"] pre.mermaid svg .titleText,
:root[data-theme="light"] pre.mermaid svg .titleText tspan {
    fill: var(--bb-ink) !important;
}

/* ── Light: edges / arrows → dark ink ─────────────────────────────
   This applies to ALL diagram types (flowchart, sequence, ER, etc.)
   so nothing is invisible on cream. */
:root[data-theme="light"] pre.mermaid svg .edgePath .path,
:root[data-theme="light"] pre.mermaid svg .flowchart-link,
:root[data-theme="light"] pre.mermaid svg path.relation,
:root[data-theme="light"] pre.mermaid svg .messageLine0,
:root[data-theme="light"] pre.mermaid svg .messageLine1,
:root[data-theme="light"] pre.mermaid svg line.messageLine0,
:root[data-theme="light"] pre.mermaid svg line.messageLine1,
:root[data-theme="light"] pre.mermaid svg .transition {
    stroke: var(--bb-ink-soft) !important;
}

:root[data-theme="light"] pre.mermaid svg marker path,
:root[data-theme="light"] pre.mermaid svg #arrowhead path,
:root[data-theme="light"] pre.mermaid svg .arrowheadPath,
:root[data-theme="light"] pre.mermaid svg .marker {
    stroke: var(--bb-ink-soft) !important;
    fill: var(--bb-ink-soft) !important;
}

/* ── Light: edge labels → dark text on cream pill ─────────────── */
:root[data-theme="light"] pre.mermaid svg .edgeLabel rect {
    fill: var(--bb-paper-sidebar) !important;
    stroke: rgb(var(--bb-green-rgb) / 0.30) !important;
}

:root[data-theme="light"] pre.mermaid svg .edgeLabel foreignObject > div {
    background-color: var(--bb-paper-sidebar) !important;
}

:root[data-theme="light"] pre.mermaid svg [class*="edgeLabel"] text,
:root[data-theme="light"] pre.mermaid svg [class*="edgeLabel"] tspan,
:root[data-theme="light"] pre.mermaid svg [class*="edgeLabel"] span,
:root[data-theme="light"] pre.mermaid svg [class*="edgeLabel"] p,
:root[data-theme="light"] pre.mermaid svg .edgeLabel text,
:root[data-theme="light"] pre.mermaid svg .edgeLabel tspan,
:root[data-theme="light"] pre.mermaid svg .edgeLabel span,
:root[data-theme="light"] pre.mermaid svg .edgeLabel p {
    background-color: transparent !important;
    color: var(--bb-ink-soft) !important;
    fill: var(--bb-ink-soft) !important;
    border: none !important;
}

:root[data-theme="light"] pre.mermaid svg .edgeLabel text,
:root[data-theme="light"] pre.mermaid svg .edgeLabel text tspan,
:root[data-theme="light"] pre.mermaid svg g.edgeLabel text,
:root[data-theme="light"] pre.mermaid svg g.edgeLabel text tspan {
    fill: var(--bb-ink-soft) !important;
    stroke: var(--bb-paper) !important;
}

/* ── Light: ALL text/tspan fallback ───────────────────────────────
   Catch-all for any text Mermaid renders that doesn't match a
   specific selector above. Nodes already have --bb-ink (dark on
   tan fills, which is readable on either bg). This targets the
   remaining "floating" text: edge labels, cluster labels, notes,
   state labels, ER labels, etc. */
:root[data-theme="light"] pre.mermaid svg .messageText {
    fill: var(--bb-ink) !important;
}

:root[data-theme="light"] pre.mermaid svg .actor-line {
    stroke: var(--bb-ink-mid) !important;
    opacity: 0.45;
}

:root[data-theme="light"] pre.mermaid svg .sequenceNumber {
    fill: var(--bb-ink) !important;
}

:root[data-theme="light"] pre.mermaid svg .labelText,
:root[data-theme="light"] pre.mermaid svg .labelText tspan,
:root[data-theme="light"] pre.mermaid svg .loopText,
:root[data-theme="light"] pre.mermaid svg .loopText tspan {
    fill: var(--bb-ink) !important;
}

:root[data-theme="light"] pre.mermaid svg .labelBox {
    fill: var(--bb-paper) !important;
    stroke: rgb(var(--bb-ink-rgb) / 0.3) !important;
}

:root[data-theme="light"] pre.mermaid svg .note {
    fill: var(--bb-paper) !important;
    stroke: rgb(var(--bb-green-rgb) / 0.35) !important;
}

:root[data-theme="light"] pre.mermaid svg .noteText,
:root[data-theme="light"] pre.mermaid svg .noteText tspan {
    fill: var(--bb-ink-soft) !important;
}

:root[data-theme="light"] pre.mermaid svg .activation0,
:root[data-theme="light"] pre.mermaid svg .activation1,
:root[data-theme="light"] pre.mermaid svg .activation2 {
    fill: rgb(var(--bb-green-rgb) / 0.15) !important;
    stroke: var(--bb-green) !important;
}

/* ── Light: clusters / subgraphs ──────────────────────────────── */
:root[data-theme="light"] pre.mermaid svg .cluster rect {
    fill: rgb(var(--bb-green-rgb) / 0.06) !important;
    stroke: rgb(var(--bb-green-rgb) / 0.30) !important;
}

:root[data-theme="light"] pre.mermaid svg [class*="cluster"] text,
:root[data-theme="light"] pre.mermaid svg [class*="cluster"] tspan,
:root[data-theme="light"] pre.mermaid svg [class*="cluster"] span,
:root[data-theme="light"] pre.mermaid svg [class*="cluster"] p,
:root[data-theme="light"] pre.mermaid svg [class*="cluster"] div,
:root[data-theme="light"] pre.mermaid svg .cluster text,
:root[data-theme="light"] pre.mermaid svg .cluster tspan,
:root[data-theme="light"] pre.mermaid svg .cluster span,
:root[data-theme="light"] pre.mermaid svg .cluster p,
:root[data-theme="light"] pre.mermaid svg .cluster div,
:root[data-theme="light"] pre.mermaid svg .cluster .nodeLabel {
    color: var(--bb-green) !important;
    fill: var(--bb-green) !important;
}

/* ── Light: state diagram labels ──────────────────────────────── */
:root[data-theme="light"] pre.mermaid svg .statediagram-state .nodeLabel,
:root[data-theme="light"] pre.mermaid svg .state-note-text,
:root[data-theme="light"] pre.mermaid svg .stateLabel text,
:root[data-theme="light"] pre.mermaid svg .stateLabel tspan {
    fill: var(--bb-ink) !important;
    color: var(--bb-ink) !important;
}

/* ── Light: ER diagram labels ─────────────────────────────────── */
:root[data-theme="light"] pre.mermaid svg .entityLabel,
:root[data-theme="light"] pre.mermaid svg .entityLabel tspan,
:root[data-theme="light"] pre.mermaid svg .relationshipLabel,
:root[data-theme="light"] pre.mermaid svg .relationshipLabel tspan {
    fill: var(--bb-ink) !important;
}


/* The fullscreen viewer covers the whole window, so panels should
   advertise their interactivity without screaming. */
pre.mermaid[data-processed].mermaid-interactive-ready {
    cursor: zoom-in;
    transition: border-color 180ms ease, box-shadow 180ms ease;
}
pre.mermaid[data-processed].mermaid-interactive-ready:hover {
    border-color: rgb(var(--bb-green-glow-rgb) / 0.45) !important;
    box-shadow:
        inset 0 1px 0 rgb(var(--bb-white-pure-rgb) / 0.04),
        0 6px 24px rgb(var(--bb-shadow-rgb) / 0.45);
}

/* ── Expand button — bottom-right corner of each panel ─────────── */
.mermaid-fullscreen-btn {
    position: absolute;
    bottom: 0.85rem;
    right: 0.85rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.75rem;
    font-family: var(--bb-font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--bb-tan-pale);
    background: rgb(var(--bb-bg-rgb) / 0.72);
    border: 1px solid rgb(var(--bb-green-glow-rgb) / 0.35);
    border-radius: 999px;
    cursor: pointer;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 160ms ease, transform 160ms ease,
                border-color 160ms ease, color 160ms ease,
                background 160ms ease;
}
pre.mermaid[data-processed]:hover .mermaid-fullscreen-btn,
pre.mermaid[data-processed]:focus-within .mermaid-fullscreen-btn,
.mermaid-fullscreen-btn:focus-visible {
    opacity: 1;
    transform: translateY(0);
}
.mermaid-fullscreen-btn:hover,
.mermaid-fullscreen-btn:focus-visible {
    color: var(--bb-white);
    border-color: var(--bb-green-glow);
    background: rgb(var(--bb-green-rgb) / 0.22);
    outline: none;
}
.mermaid-fullscreen-btn svg {
    width: 14px;
    height: 14px;
    display: block;
}

:root[data-theme="light"] .mermaid-fullscreen-btn {
    color: var(--bb-ink);
    background: rgb(var(--bb-paper-sidebar-rgb, 243 236 219) / 0.85);
    border-color: rgb(var(--bb-green-rgb) / 0.45);
}
:root[data-theme="light"] .mermaid-fullscreen-btn:hover,
:root[data-theme="light"] .mermaid-fullscreen-btn:focus-visible {
    color: var(--bb-ink);
    background: rgb(var(--bb-green-rgb) / 0.14);
    border-color: var(--bb-green);
}

/* ════════════════════════════════════════════════════════════════════
   FULLSCREEN MODAL — covers the viewport, holds the cloned SVG that
   panzoom drives. Theme variables on <html> still apply, so the
   cloned SVG inherits all the same node/edge/label styling from the
   rules above.
   ════════════════════════════════════════════════════════════════════ */
.mermaid-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    isolation: isolate;
}
.mermaid-modal.mermaid-modal--open {
    display: block;
}

.mermaid-modal__backdrop {
    position: absolute;
    inset: 0;
    /* Tinted backdrop: brand-green wash bleeding into tan, then a
       deep ink vignette. Pulls the eye onto the diagram while still
       feeling like part of the ItsBagelBot palette. */
    background:
        radial-gradient(
            70% 60% at 18% 12%,
            rgb(var(--bb-green-rgb) / 0.42),
            transparent 65%
        ),
        radial-gradient(
            65% 55% at 82% 88%,
            rgb(var(--bb-tan-deep-rgb) / 0.38),
            transparent 60%
        ),
        radial-gradient(
            100% 100% at 50% 50%,
            rgb(var(--bb-mermaid-panel-rgb, 13 12 10) / 0.85),
            rgb(var(--bb-bg-rgb) / 0.97) 75%
        );
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    animation: bb-modal-fade 220ms ease-out;
}
:root[data-theme="light"] .mermaid-modal__backdrop {
    background:
        radial-gradient(
            70% 60% at 18% 12%,
            rgb(var(--bb-green-rgb) / 0.22),
            transparent 65%
        ),
        radial-gradient(
            65% 55% at 82% 88%,
            rgb(var(--bb-tan-deep-rgb) / 0.20),
            transparent 60%
        ),
        radial-gradient(
