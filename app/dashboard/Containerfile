# Dashboard (Go) - build with podman or docker:
#   podman build -t itsbagelbot/dashboard -f Containerfile .
FROM golang:1.26-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go run github.com/a-h/templ/cmd/templ@v0.3.857 generate \
 && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /dashboard .

# ---------------------------------------------------------------------------
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /dashboard /dashboard

USER nonroot
EXPOSE 8080
ENTRYPOINT ["/dashboard"]
