# loyalty (Go, root module) - build from the REPO ROOT:
#   podman build -t itsbagelbot/loyalty -f app/loyalty/Containerfile .
FROM docker.io/library/golang:1.26-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY internal/domain internal/domain
COPY internal/moderation internal/moderation
COPY internal/utils internal/utils
COPY pkg pkg
COPY app/loyalty app/loyalty
RUN go run -mod=mod entgo.io/ent/cmd/ent generate --feature sql/upsert ./app/loyalty/ent/schema \
 && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /loyalty ./app/loyalty

# ---------------------------------------------------------------------------
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /loyalty /loyalty

USER nonroot
ENTRYPOINT ["/loyalty"]
