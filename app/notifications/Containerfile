# notifications (Go, root module) - build from the REPO ROOT:
#   podman build -t itsbagelbot/notifications -f app/notifications/Containerfile .
FROM docker.io/library/golang:1.26-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY internal/domain internal/domain
COPY internal/utils internal/utils
COPY pkg pkg
COPY app/notifications app/notifications
RUN go run -mod=mod entgo.io/ent/cmd/ent generate --feature sql/upsert ./app/notifications/ent/schema \
 && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /notifications ./app/notifications

# ---------------------------------------------------------------------------
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /notifications /notifications

USER nonroot
ENTRYPOINT ["/notifications"]
