# users (Go, root module) - build from the REPO ROOT:
#   podman build -t itsbagelbot/users -f app/users/Containerfile .
FROM docker.io/library/golang:1.25-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY internal/domain internal/domain
COPY internal/utils internal/utils
COPY pkg pkg
COPY app/users app/users
RUN go run -mod=mod entgo.io/ent/cmd/ent generate ./app/users/ent/schema \
 && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /users ./app/users

# ---------------------------------------------------------------------------
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /users /users

USER nonroot
ENTRYPOINT ["/users"]
