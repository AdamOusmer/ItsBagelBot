from docker.io/library/golang:1.25-bookworm AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY internal/domain internal/domain
COPY internal/projection internal/projection
COPY internal/utils internal/utils
COPY pkg pkg
COPY app/worker app/worker
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /worker ./app/worker

# ---------------------------------------------------------------------------
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /worker /worker

USER nonroot
ENTRYPOINT ["/worker"]
