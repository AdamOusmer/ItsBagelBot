# outgress (Go, root module) - build from the REPO ROOT:
#   podman build -t itsbagelbot/outgress -f app/outgress/Containerfile .
FROM docker.io/library/golang:1.26-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY internal/domain internal/domain
COPY internal/utils internal/utils
COPY pkg pkg
COPY app/outgress app/outgress
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /outgress ./app/outgress

# ---------------------------------------------------------------------------
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /outgress /outgress

USER nonroot
ENTRYPOINT ["/outgress"]
