# projector (Go, root module) - build from the REPO ROOT:
#   podman build -t itsbagelbot/projector -f app/projector/Containerfile .
FROM docker.io/library/golang:1.26-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY internal/domain internal/domain
COPY internal/utils internal/utils
COPY pkg pkg
COPY app/projector app/projector
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /projector ./app/projector

# ---------------------------------------------------------------------------
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /projector /projector

USER nonroot
ENTRYPOINT ["/projector"]
