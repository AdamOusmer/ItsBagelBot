# broadcaster-data (Go, root module) - build from the REPO ROOT:
#   podman build -t itsbagelbot/broadcaster-data -f app/broadcaster-data/Containerfile .
FROM golang:1.26-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY internal internal
COPY pkg pkg
COPY app/broadcaster-data app/broadcaster-data
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /broadcaster-data ./app/broadcaster-data

# ---------------------------------------------------------------------------
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /broadcaster-data /broadcaster-data

USER nonroot
EXPOSE 8080
ENTRYPOINT ["/broadcaster-data"]
