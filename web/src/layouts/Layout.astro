---
import '../styles/style.css';

import { ClientRouter } from 'astro:transitions';
import Cursor from '../components/ui/Cursor.astro'
import Footer from '../components/layout/Footer.astro'
import Nav from "../components/layout/Nav.astro";
import Brackets from '../components/ui/Brackets.astro'
import ReadingProgress from '../components/ui/ReadingProgress.astro'
import { getLangFromUrl, LOCALIZED_PATHS, locales, defaultLang, splitLocale, localizePath, useTranslations } from '../i18n/ui';

interface Props {
    title?: string;
    description?: string;
    /** Share-card image: absolute URL or site-root path. Defaults to /og-image.png. */
    image?: string;
    /** Open Graph object type. 'website' for landing pages, 'article' for legal/docs. */
    ogType?: string;
    /** Keep the page out of search indexes (still crawlable for link discovery). */
    noindex?: boolean;
}

const {
    title = 'ItsBagelBot. Your Stream, Your Rules',
    description = 'The all-in-one Twitch companion baked for independence. Automated moderation, custom commands, and engagement tools.',
    image = '/og-image.png',
    ogType = 'website',
    noindex = false,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Absolute URLs for canonical + social cards. Astro.site is the production
// origin (astro.config); resolving against it turns page-relative paths into
// the fully-qualified URLs crawlers and share-card scrapers require.
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(image, Astro.site).href;
const siteName = 'ItsBagelBot';
const ogLocale = t('lang.ogLocale');
// One og:locale:alternate per other locale, each in its own tongue's code.
const altOgLocales = locales.filter((l) => l !== lang).map((l) => useTranslations(l)('lang.ogLocale'));

// Let AI answer-engines and search bots pull the biggest preview + full
// snippet; noindex pages still allow link-following for discovery.
const robotsContent = noindex
    ? 'noindex, follow'
    : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

// Structured data (@graph): who publishes the site, the site itself, and the
// product. Search engines and LLMs read this to describe ItsBagelBot precisely
// (name, free pricing, feature list, official links). type="application/ld+json"
// is a non-executable data island, so the strict script-src CSP doesn't gate it.
const ORIGIN = new URL(Astro.site!).origin;
const structuredData = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'Organization',
            '@id': `${ORIGIN}/#organization`,
            name: siteName,
            url: `${ORIGIN}/`,
            logo: `${ORIGIN}/android-chrome-512x512.png`,
            description,
            sameAs: [
                'https://twitch.tv/itsbagelbot',
                'https://discord.gg/SZ2remwSDv',
                'https://github.com/AdamOusmer/ItsBagelBot',
            ],
        },
        {
            '@type': 'WebSite',
            '@id': `${ORIGIN}/#website`,
            url: `${ORIGIN}/`,
            name: siteName,
            description,
            inLanguage: [...locales],
            publisher: { '@id': `${ORIGIN}/#organization` },
        },
        {
            '@type': 'SoftwareApplication',
            '@id': `${ORIGIN}/#software`,
            name: siteName,
            applicationCategory: 'UtilitiesApplication',
            applicationSubCategory: 'Twitch chat bot',
            operatingSystem: 'Web',
            url: `${ORIGIN}/`,
            image: `${ORIGIN}/og-image.png`,
            description,
            publisher: { '@id': `${ORIGIN}/#organization` },
            offers: {
                '@type': 'Offer',
                price: '0',
                priceCurrency: 'USD',
                availability: 'https://schema.org/InStock',
            },
            featureList: [
                'Automated chat moderation',
                'Custom commands and variables',
                'Timers',
                'Channel Points rewards',
                'Giveaways',
                'Song requests',
                'Polls',
                'Game stat integrations (Hypixel Bedwars, MCSR Ranked, Fortnite)',
            ],
        },
    ],
};

// hreflang alternates for the routes that exist in every locale, so search
// engines pair the translated versions instead of treating them as duplicates.
// splitLocale strips any locale prefix to the shared base path; each locale then
// re-localizes it. x-default points at the default locale.
const { path: basePath } = splitLocale(Astro.url.pathname);
const hasAlternates = LOCALIZED_PATHS.has(basePath);
const alternates = hasAlternates
    ? locales.map((l) => ({ lang: l, href: new URL(localizePath(basePath, l), Astro.site).href }))
    : [];
const xDefaultHref = new URL(localizePath(basePath, defaultLang), Astro.site).href;

const devScriptSources = import.meta.env.DEV
    ? " 'unsafe-inline' 'unsafe-eval'"
    : "";
const devConnectSources = import.meta.env.DEV
    ? " ws://localhost:* ws://127.0.0.1:* http://localhost:* http://127.0.0.1:*"
    : "";
const contentSecurityPolicy = [
    "default-src 'self'",
    "img-src 'self' data:",
    "style-src 'self' 'unsafe-inline' https://fonts.googleapis.com",
    "font-src 'self' https://fonts.gstatic.com",
    `script-src 'self'${devScriptSources} https://static.cloudflareinsights.com`,
    `connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://cloudflareinsights.com${devConnectSources}`,
    "base-uri 'self'",
    "form-action 'self'",
].join('; ');
---


<!doctype html>
<html lang={lang}>

<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
    <meta
        http-equiv="Content-Security-Policy"
        content={contentSecurityPolicy}
    />
    <meta name="referrer" content="strict-origin-when-cross-origin"/>

    <link rel="canonical" href={canonicalURL}/>
    <meta name="robots" content={robotsContent}/>

    <!-- Browser-chrome tint: matches the dark page bg so the mobile address
         bar blends instead of clashing. -->
    <meta name="theme-color" content="#0a0a0a"/>
    <meta name="color-scheme" content="dark"/>

    <meta name="generator" content={Astro.generator}/>

    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&family=DM+Sans:ital,wght@0,400;1,400&family=Caveat:wght@500;600&display=swap"
          rel="stylesheet"/>

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=bot-1">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=bot-1">
    <link rel="shortcut icon" href="/favicon.ico?v=bot-1">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">

    <meta name="description" content={description} />
    <meta name="application-name" content={siteName} />
    <meta name="apple-mobile-web-app-title" content={siteName} />

    <!-- Open Graph: link previews on Discord, Facebook, LinkedIn, iMessage. -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${siteName} — ${description}`} />
    <meta property="og:locale" content={ogLocale} />
    {altOgLocales.map((code) => (
        <meta property="og:locale:alternate" content={code} />
    ))}

    <!-- Twitter/X large summary card. -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={`${siteName} — ${description}`} />

    {hasAlternates && (
        <Fragment>
            {alternates.map((alt) => (
                <link rel="alternate" hreflang={alt.lang} href={alt.href} />
            ))}
            <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
        </Fragment>
    )}

    <title>{title}</title>

    <!-- SPA-style navigation. The site's components re-init on
         astro:page-load and clean up on astro:before-swap; this wires them up.
         Uses Astro's default view transition (no custom ::view-transition
         animation). The router script is bundled (assetsInlineLimit:0 keeps it
         external) so it stays within the strict script-src 'self' CSP. -->
    <ClientRouter />

    <!-- Structured data for search engines + LLM answer engines. -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />
</head>

<body>
    <a class="skip-link" href="#main-content">{t('skip.toContent')}</a>
    <main id="main-content">
        <slot/>
    </main>
    <Nav/>
    <ReadingProgress/>
    <Brackets/>
    <Footer/>
    <Cursor/>

    <script>
        import '../script/scroll.js';
        import '../script/dom-motion/index.js';
        import '../script/reveal.js';
        import '../script/interactions.js';
        import '../script/lightfield.js';
        import '../script/decode.js';
        import '../script/easter-egg';
    </script>

</body>
</html>

<style>
    .skip-link {
        position: absolute;
        left: 12px;
        top: -60px;
        z-index: 200;
        padding: 10px 16px;
        border-radius: 8px;
        background: var(--card-bg, #111110);
        border: 1px solid var(--tan, #c9a87c);
        color: var(--tan-light, #e0c49a);
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.8rem;
        text-decoration: none;
        transition: top 200ms ease;
    }

    .skip-link:focus {
        top: 12px;
    }

    /* No box: keeps the landmark for a11y without disturbing the hero/Encryption
       sticky + scroll math (which assumes top-level sections are body children). */
    main {
        display: contents;
    }
</style>
