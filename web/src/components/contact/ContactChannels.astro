---
import Card from '../ui/Card.astro';

interface Channel {
    icon: string;
    title: string;
    description: string;
    href: string;
    external?: boolean;
    copyEmail?: string;
}

const channels: Channel[] = [
    {
        icon: 'discord',
        title: 'Discord',
        description: 'Join our community for support, feature requests, and updates.',
        href: 'https://discord.gg/SZ2remwSDv',
        external: true,
    },
    {
        icon: 'mail',
        title: 'General Support',
        description: 'Reach us at support@itsbagelbot.com for account help or questions.',
        href: 'mailto:support@itsbagelbot.com',
        copyEmail: 'support@itsbagelbot.com',
    },
    {
        icon: 'building',
        title: 'Enterprise Sales',
        description: 'Contact enterprise@itsbagelbot.com for custom plans and dedicated infrastructure.',
        href: 'mailto:enterprise@itsbagelbot.com',
        copyEmail: 'enterprise@itsbagelbot.com',
    },
    {
        icon: 'github',
        title: 'GitHub',
        description: 'Report bugs, browse the source, and track development progress.',
        href: 'https://github.com/AdamOusmer/ItsBagelBot',
        external: true,
    },
];
---

<section class="channels">
    <div class="channels__grid">
        {channels.map((channel, i) => (
            <Card
                as="a"
                href={channel.href}
                class="channels__card"
                data-reveal
                style={`--reveal-i: ${i}`}
                target={channel.external ? '_blank' : undefined}
                rel={channel.external ? 'noopener noreferrer' : undefined}
            >
                <div class="channels__header">
                    <div class="channels__icon">
                        {channel.icon === 'discord' && (
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
                                <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z" />
                            </svg>
                        )}
                        {channel.icon === 'mail' && (
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="4" width="20" height="16" rx="2" />
                                <path d="M22 7l-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                            </svg>
                        )}
                        {channel.icon === 'building' && (
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="4" y="2" width="16" height="20" rx="2" ry="2" />
                                <path d="M9 22v-4h6v4" />
                                <path d="M8 6h.01" />
                                <path d="M16 6h.01" />
                                <path d="M12 6h.01" />
                                <path d="M12 10h.01" />
                                <path d="M12 14h.01" />
                                <path d="M16 10h.01" />
                                <path d="M16 14h.01" />
                                <path d="M8 10h.01" />
                                <path d="M8 14h.01" />
                            </svg>
                        )}
                        {channel.icon === 'github' && (
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                                <path d="M9 18c-4.51 2-5-2-7-2" />
                            </svg>
                        )}
                    </div>
                    {channel.copyEmail && (
                        <button
                            type="button"
                            class="channels__copy"
                            data-copy={channel.copyEmail}
                            aria-label={`Copy ${channel.copyEmail}`}
                        >
                            <span class="channels__copy-default" aria-hidden="true">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                                </svg>
                            </span>
                            <span class="channels__copy-done" aria-hidden="true">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                            </span>
                        </button>
                    )}
                </div>
                <h3 class="channels__title">{channel.title}</h3>
                <p class="channels__desc">{channel.description}</p>
            </Card>
        ))}
    </div>
</section>

<style>
    .channels {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 24px 80px;
    }

    .channels__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
    }

    .channels__card {
        /* layout override: card body stacks icon row then title then desc */
    }

    .channels__header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .channels__icon {
        color: var(--green-glow, #52b788);
        line-height: 0;
    }

    .channels__title {
        font-family: var(--font-display, "Syne", sans-serif);
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--white, #f0ece4);
        margin-bottom: 8px;
    }

    .channels__desc {
        font-family: var(--font-body, "DM Sans", sans-serif);
        font-size: 0.88rem;
        color: var(--muted, #888077);
        line-height: 1.6;
    }

    /* Copy button */
    .channels__copy {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        flex-shrink: 0;
        background: transparent;
        border: 1px solid var(--border, rgba(201, 168, 124, 0.15));
        border-radius: 6px;
        color: var(--muted, #888077);
        cursor: pointer;
        transition:
            color 200ms ease,
            border-color 200ms ease,
            background 200ms ease;
        /* pull it up to align with the icon visually */
        margin-top: 2px;
    }

    .channels__copy:hover {
        color: var(--tan-light, #e0c49a);
        border-color: rgba(201, 168, 124, 0.35);
        background: rgba(201, 168, 124, 0.06);
    }

    /* Default: show copy icon; hide check */
    .channels__copy-done {
        display: none;
    }

    /* Copied state: swap to check, green tint */
    .channels__copy.is-copied {
        color: var(--green-glow, #52b788);
        border-color: rgba(82, 183, 136, 0.35);
        background: rgba(82, 183, 136, 0.08);
    }

    .channels__copy.is-copied .channels__copy-default {
        display: none;
    }

    .channels__copy.is-copied .channels__copy-done {
        display: flex;
    }

    @media (min-width: 768px) {
        .channels__grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
