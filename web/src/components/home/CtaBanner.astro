---
import MainButton from '../ui/Buttons/MainButton.astro';
import SecondaryButton from '../ui/Buttons/SecondaryButton.astro';
---

<div class="cta-banner">
    <div class="cta-banner__inner" data-reveal>
        <h2 class="cta-banner__title">Ready to upgrade your stream?</h2>
        <p class="cta-banner__desc">Join thousands of streamers who trust ItsBagelBot for their chat.</p>

        <div class="cta-banner__actions">
            <span data-magnetic>
                <MainButton href="https://dashboard.itsbagelbot.com" label="Add to Twitch" />
            </span>
            <SecondaryButton href="/pricing" label="View Pricing" />
        </div>
    </div>
</div>

<style>
    .cta-banner {
        width: 100%;
        background: linear-gradient(180deg, rgba(45, 106, 79, 0.08) 0%, transparent 100%);
        border-top: 1px solid var(--border, rgba(201, 168, 124, 0.15));
        padding: 80px 24px;
        position: relative;
        z-index: 2;
    }

    .cta-banner__inner {
        max-width: 600px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .cta-banner__title {
        font-family: var(--font-display, "Syne", sans-serif);
        font-weight: 800;
        font-size: clamp(2rem, 5vw, 3rem);
        color: var(--white, #f0ece4);
        margin-bottom: 16px;
        line-height: 1.1;
        letter-spacing: -0.01em;
    }

    .cta-banner__desc {
        font-family: var(--font-body, "DM Sans", sans-serif);
        font-size: 1.05rem;
        color: var(--muted, #888077);
        margin-bottom: 32px;
        line-height: 1.6;
    }

    .cta-banner__actions {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap: 16px;
    }

    @media (max-width: 480px) {
        .cta-banner__actions {
            flex-direction: column;
            width: 100%;
        }

        .cta-banner__actions > * {
            width: 100%;
            text-align: center;
        }
    }
</style>
