---
import Card from '../ui/Card.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="am" id="auto-mod">
    <SectionHeading eyebrow={t('automod.eyebrow')} title={t('automod.title')} />

    <div class="am__grid">
        <!-- Classifier Jury -->
        <Card class="am__card am__card--wide" data-reveal>
            <div class="am__demo am__demo--jury" aria-hidden="true">
                <div class="am-jury__msg-wrapper">
                    <span class="am-jury__msg">CLICK HERE FOR FREE SUBS!!</span>
                    <span class="am-jury__sweep"></span>
                </div>
                <div class="am-jury__bottom">
                    <div class="am-jury__votes">
                        <span class="am-jury__vote" style="--d: 0s"></span>
                        <span class="am-jury__vote" style="--d: 0.15s"></span>
                        <span class="am-jury__vote am-jury__vote--green" style="--d: 0.3s"></span>
                        <span class="am-jury__vote" style="--d: 0.45s"></span>
                        <span class="am-jury__vote" style="--d: 0.6s"></span>
                    </div>
                    <span class="am-jury__verdict">BLOCKED</span>
                </div>
            </div>
            <h3 class="am__title">
                {t('automod.juryTitle')}
                <span class="badge-incoming">{t('badge.incoming')}</span>
            </h3>
            <p class="am__desc">{t('automod.juryDesc')}</p>
        </Card>

        <!-- Static Gates -->
        <Card class="am__card" data-reveal style="--reveal-i: 1">
            <div class="am__demo am__demo--gates" aria-hidden="true">
                <div class="am-gate__container">
                    <div class="am-gate__wall"></div>
                    <span class="am-gate__dot am-gate__dot--bot" style="--d: 0s"></span>
                    <span class="am-gate__dot am-gate__dot--bot" style="--d: 1.5s"></span>
                    <span class="am-gate__dot am-gate__dot--user" style="--d: 3s"></span>
                    <span class="am-gate__dot am-gate__dot--bot" style="--d: 4.5s"></span>
                </div>
            </div>
            <h3 class="am__title">{t('automod.gatesTitle')}</h3>
            <p class="am__desc">{t('automod.gatesDesc')}</p>
        </Card>

        <!-- Reputation Engine -->
        <Card class="am__card" data-reveal style="--reveal-i: 2">
            <div class="am__demo am__demo--rep" aria-hidden="true">
                <div class="am-rep__line">
                    <span class="am-rep__user">new_user:</span>
                    <span class="am-rep__msg-wrapper">
                        <span class="am-rep__msg">LMAO ALL CAPS HYPE</span>
                        <span class="am-rep__sweep"></span>
                    </span>
                    <span class="am-rep__verdict-blocked">BLOCKED</span>
                </div>
                <div class="am-rep__line">
                    <span class="am-rep__user am-rep__user--trusted">trusted_viewer:</span>
                    <span class="am-rep__msg">LMAO ALL CAPS HYPE</span>
                    <span class="am-rep__badge">BYPASS</span>
                </div>
            </div>
            <h3 class="am__title">{t('automod.reputationTitle')}</h3>
            <p class="am__desc">{t('automod.reputationDesc')}</p>
        </Card>

        <!-- Centralized Hive -->
        <Card class="am__card am__card--wide" data-reveal style="--reveal-i: 3">
            <div class="am__demo am__demo--hive" aria-hidden="true">
                <div class="am-hive__net">
                    <span class="am-hive__node am-hive__node--center"></span>
                    <span class="am-hive__node am-hive__node--sat" style="--r: 0deg"></span>
                    <span class="am-hive__node am-hive__node--sat" style="--r: 60deg"></span>
                    <span class="am-hive__node am-hive__node--sat" style="--r: 120deg"></span>
                    <span class="am-hive__node am-hive__node--sat" style="--r: 180deg"></span>
                    <span class="am-hive__node am-hive__node--sat" style="--r: 240deg"></span>
                    <span class="am-hive__node am-hive__node--sat" style="--r: 300deg"></span>
                </div>
            </div>
            <h3 class="am__title">{t('automod.hiveTitle')}</h3>
            <p class="am__desc">{t('automod.hiveDesc')}</p>
        </Card>
    </div>
</section>

<style>
    .am {
        position: relative;
        padding: var(--space-section, 96px) 24px;
        max-width: var(--content-max, 1200px);
        margin: 0 auto;
        z-index: 3;
    }

    .am__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
    }

    @media (min-width: 720px) {
        .am__grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (min-width: 1024px) {
        .am__grid { grid-template-columns: repeat(6, 1fr); }
        .am__card { grid-column: span 2; }
        .am__card--wide { grid-column: span 3; }
    }

    .am__title {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
        font-family: var(--font-display, "Syne", sans-serif);
        font-size: 1.06rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: var(--white, #f0ece4);
        margin: 0 0 8px;
    }

    .badge-incoming {
        display: inline-flex;
        align-items: center;
        padding: 5px 12px;
        border-radius: 100px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(82, 183, 136, 0.4);
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--green-glow, #52b788);
    }

    .am__desc {
        font-family: var(--font-body, "DM Sans", sans-serif);
        font-size: 0.86rem;
        line-height: 1.6;
        color: var(--muted, #888077);
        margin: 0;
    }

    /* ── Demo stage shared (Matches QuietWork exactly) ── */
    .am__demo {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 8px;
        height: 84px;
        margin-bottom: 20px;
        padding: 14px 16px;
        border-radius: 10px;
        background: rgba(10, 10, 10, 0.55);
        border: 1px solid rgba(240, 236, 228, 0.05);
        overflow: hidden;
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.74rem;
        position: relative;
    }

    /* ── Classifier Jury ── */
    .am-jury__msg-wrapper {
        position: relative;
        display: inline-block;
        width: fit-content;
        max-width: 100%;
        color: rgba(217, 138, 138, 0.85);
        animation: amJuryLine 6s ease-in-out infinite;
    }

    .am-jury__sweep {
        position: absolute;
        inset: -2px -4px;
        border-radius: 4px;
        background: linear-gradient(90deg, transparent, rgba(217, 138, 138, 0.35), transparent);
        transform: translateX(-110%);
        animation: amJurySweep 6s ease-in-out infinite;
    }

    .am-jury__bottom {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .am-jury__votes {
        display: flex;
        gap: 4px;
    }

    .am-jury__vote {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
        animation: amJuryVote 6s ease-in-out infinite;
        animation-delay: var(--d);
    }

    .am-jury__vote--green {
        animation-name: amJuryVoteGreen;
    }

    .am-jury__verdict {
        color: rgba(217, 138, 138, 1);
        font-weight: bold;
        opacity: 0;
        animation: amJuryVerdict 6s ease-in-out infinite;
    }

    @keyframes amJuryLine {
        0%, 38% { opacity: 1; filter: none; }
        48%, 88% { opacity: 0.28; filter: blur(1.5px); text-decoration: line-through; }
        98%, 100% { opacity: 1; filter: none; }
    }

    @keyframes amJurySweep {
        0%, 34% { transform: translateX(-110%); }
        46%, 100% { transform: translateX(110%); }
    }

    @keyframes amJuryVote {
        0%, 15% { background: rgba(255, 255, 255, 0.1); }
        20%, 88% { background: rgba(217, 138, 138, 1); box-shadow: 0 0 6px rgba(217, 138, 138, 0.6); }
        95%, 100% { background: rgba(255, 255, 255, 0.1); }
    }

    @keyframes amJuryVoteGreen {
        0%, 15% { background: rgba(255, 255, 255, 0.1); }
        20%, 88% { background: var(--green-glow, #52b788); box-shadow: 0 0 6px rgba(82, 183, 136, 0.6); }
        95%, 100% { background: rgba(255, 255, 255, 0.1); }
    }

    @keyframes amJuryVerdict {
        0%, 44% { opacity: 0; transform: translateY(4px); }
        54%, 86% { opacity: 1; transform: none; }
        96%, 100% { opacity: 0; }
    }

    /* ── Static Gates ── */
    .am-gate__container {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .am-gate__wall {
        position: absolute;
        right: 20%;
        top: 10%;
        bottom: 10%;
        width: 2px;
        background: rgba(255, 255, 255, 0.1);
        animation: amGateWall 6s infinite;
    }

    .am-gate__dot {
        position: absolute;
        left: 10%;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        opacity: 0;
        animation: amGateDotBot 6s linear infinite;
        animation-delay: var(--d);
        background: rgba(217, 138, 138, 1);
    }

    .am-gate__dot--user {
        background: var(--green-glow, #52b788);
        animation-name: amGateDotUser;
    }

    @keyframes amGateDotBot {
        0% { opacity: 0; transform: translateX(0); }
        10% { opacity: 1; transform: translateX(20px); }
        45% { opacity: 1; transform: translateX(180px); } /* Hits wall */
        50% { opacity: 0; transform: translateX(160px) translateY(-10px); } /* Bounce back */
        100% { opacity: 0; }
    }

    @keyframes amGateDotUser {
        0% { opacity: 0; transform: translateX(0); }
        10% { opacity: 1; transform: translateX(20px); }
        45% { opacity: 1; transform: translateX(180px); } /* Reaches wall */
        80% { opacity: 1; transform: translateX(300px); } /* Passes through */
        90% { opacity: 0; transform: translateX(340px); }
        100% { opacity: 0; }
    }

    @keyframes amGateWall {
        0%, 40% { background: rgba(255, 255, 255, 0.1); box-shadow: none; width: 2px; }
        45%, 48% { background: rgba(217, 138, 138, 1); box-shadow: 0 0 10px rgba(217, 138, 138, 0.8); width: 4px; }
        52%, 100% { background: rgba(255, 255, 255, 0.1); box-shadow: none; width: 2px; }
    }

    /* ── Reputation Engine ── */
    .am__demo--rep {
        justify-content: center;
        gap: 12px;
    }

    .am-rep__line {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .am-rep__user {
        color: var(--muted);
    }

    .am-rep__user--trusted {
        color: var(--tan-light, #e0c49a);
    }

    .am-rep__msg-wrapper {
        position: relative;
        display: inline-block;
        color: rgba(217, 138, 138, 0.85);
        animation: amRepLine 6s ease-in-out infinite;
    }

    .am-rep__msg {
        color: var(--white);
    }
    
    .am-rep__msg-wrapper .am-rep__msg {
        color: inherit;
    }

    .am-rep__sweep {
        position: absolute;
        inset: -2px -4px;
        border-radius: 4px;
        background: linear-gradient(90deg, transparent, rgba(217, 138, 138, 0.35), transparent);
        transform: translateX(-110%);
        animation: amRepSweep 6s ease-in-out infinite;
    }

    .am-rep__verdict-blocked {
        color: rgba(217, 138, 138, 1);
        font-weight: bold;
        opacity: 0;
        animation: amRepBlocked 6s ease-in-out infinite;
    }

    .am-rep__badge {
        color: var(--green-glow, #52b788);
        border: 1px solid rgba(82, 183, 136, 0.4);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.6rem;
        opacity: 0;
        animation: amRepAllowed 6s ease-in-out infinite;
    }

    @keyframes amRepLine {
        0%, 28% { opacity: 1; filter: none; }
        38%, 78% { opacity: 0.28; filter: blur(1.5px); text-decoration: line-through; }
        88%, 100% { opacity: 1; filter: none; }
    }

    @keyframes amRepSweep {
        0%, 24% { transform: translateX(-110%); }
        36%, 100% { transform: translateX(110%); }
    }

    @keyframes amRepBlocked {
        0%, 34% { opacity: 0; transform: translateY(4px); }
        44%, 76% { opacity: 1; transform: none; }
        86%, 100% { opacity: 0; }
    }

    @keyframes amRepAllowed {
        0%, 24% { opacity: 0; transform: scale(0.9); }
        34%, 86% { opacity: 1; transform: scale(1); }
        96%, 100% { opacity: 0; }
    }


    /* ── Centralized Hive ── */
    .am__demo--hive {
        align-items: center;
    }
    
    .am-hive__net {
        position: relative;
        width: 40px;
        height: 40px;
    }

    .am-hive__node {
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.2);
    }

    .am-hive__node--center {
        width: 10px;
        height: 10px;
        top: 15px;
        left: 15px;
        animation: amHiveCenter 4s infinite;
    }

    .am-hive__node--sat {
        width: 6px;
        height: 6px;
        top: 17px;
        left: 17px;
        transform: rotate(var(--r)) translateY(-24px);
        animation: amHiveSat 4s infinite;
    }

    @keyframes amHiveCenter {
        0%, 10% { background: rgba(255, 255, 255, 0.2); box-shadow: none; }
        15%, 50% { background: rgba(217, 138, 138, 1); box-shadow: 0 0 10px rgba(217, 138, 138, 0.8); }
        60%, 100% { background: rgba(255, 255, 255, 0.2); box-shadow: none; }
    }

    @keyframes amHiveSat {
        0%, 25% { background: rgba(255, 255, 255, 0.2); box-shadow: none; }
        30%, 50% { background: rgba(217, 138, 138, 1); box-shadow: 0 0 8px rgba(217, 138, 138, 0.6); }
        60%, 100% { background: rgba(255, 255, 255, 0.2); box-shadow: none; }
    }

    @media (prefers-reduced-motion: reduce) {
        .am-jury__msg-wrapper, .am-jury__sweep, .am-jury__vote, .am-jury__verdict,
        .am-gate__dot, .am-gate__wall,
        .am-rep__msg-wrapper, .am-rep__sweep, .am-rep__verdict-blocked, .am-rep__badge,
        .am-hive__node--center, .am-hive__node--sat {
            animation: none !important;
            opacity: 1 !important;
            transform: none !important;
            filter: none !important;
        }
    }
</style>
