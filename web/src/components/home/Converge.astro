---
import { Image } from 'astro:assets';
import logoImage from '../../assets/LogoBOT.png';

// Scattered bot chips that get pulled into the bagel as you scroll.
// --bx / --by are their resting offsets (vmin) from centre; --r a small idle drift seed.
const bots = [
    { name: '@ModBot',    x: -34, y: -22, d: 0 },
    { name: '@SongBot',   x:  32, y: -26, d: 1 },
    { name: '@PointsBot', x: -40, y:  10, d: 2 },
    { name: '@PollBot',   x:  38, y:   6, d: 3 },
    { name: '@ClipBot',   x: -26, y:  28, d: 4 },
    { name: '@TimerBot',  x:  24, y:  30, d: 5 },
    { name: '@QuoteBot',  x:   2, y: -36, d: 6 },
];
---

<section class="cv" data-scene>
    <div class="cv__pin">
        <div class="cv__bg" aria-hidden="true"></div>

        <div class="cv__head">
            <span class="cv__kicker">We've been in your chat</span>
            <h2 class="cv__title cv__title--problem" data-decode>A dozen bots. One chat.</h2>
            <h2 class="cv__title cv__title--solved" aria-hidden="true">One bagel. Every tool.</h2>
            <p class="cv__sub cv__sub--problem">
                Mod bot, song bot, points bot, poll bot. Each with its own login, its own
                dashboard, its own headaches.
            </p>
            <p class="cv__sub cv__sub--solved" aria-hidden="true">
                ItsBagelBot replaces the whole stack. One bot in chat, one dashboard to run
                your stream.
            </p>
        </div>

        <div class="cv__stage" aria-hidden="true">
            <span class="cv__ring cv__ring--1"></span>
            <span class="cv__ring cv__ring--2"></span>
            <span class="cv__ring cv__ring--3"></span>

            {bots.map((bot) => (
                <span class="cv__bot" style={`--bx: ${bot.x}; --by: ${bot.y}; --d: ${bot.d};`}>
                    <span class="cv__bot-dot"></span>
                    {bot.name}
                </span>
            ))}

            <span class="cv__bagel">
                <Image src={logoImage} alt="" width={120} height={120} />
            </span>
        </div>
    </div>
</section>

<style>
    /* Tall scene → its sticky pin scrubs over this height. */
    .cv {
        position: relative;
        height: 420vh;
        max-width: none;
        margin: 0;
        padding: 0;
        --solved: clamp(0, calc((var(--p, 0) - 0.55) / 0.32), 1);
        --gone: clamp(0, calc((0.6 - var(--p, 0)) / 0.28), 1);
        --pull: clamp(0, calc(var(--p, 0) / 0.62), 1);
    }

    .cv__pin {
        position: sticky;
        top: 0;
        height: 100vh;
        width: 100%;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        z-index: 2;
    }

    /* Warm field that rises as the bots resolve into one bagel. */
    .cv__bg {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            radial-gradient(60% 50% at 50% 42%, rgba(201, 168, 124, calc(0.10 + var(--solved) * 0.16)), transparent 70%),
            radial-gradient(70% 60% at 50% 120%, rgba(82, 183, 136, 0.10), transparent 70%);
        opacity: calc(0.5 + var(--p, 0) * 0.5);
    }

    /* ── Headlines ── */
    .cv__head {
        position: relative;
        z-index: 3;
        width: min(680px, 88vw);
        margin-bottom: clamp(280px, 46vh, 440px);
        pointer-events: none;
    }

    .cv__kicker {
        display: block;
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.74rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--green-glow, #52b788);
        margin-bottom: 18px;
    }

    .cv__title {
        font-family: var(--font-display, "Syne", sans-serif);
        font-weight: 800;
        font-size: clamp(2rem, 6.5vw, 4rem);
        line-height: 1.02;
        letter-spacing: -0.03em;
        color: var(--white, #f0ece4);
    }

    /* Problem + solved headlines occupy the same slot and cross-fade. */
    .cv__title--solved,
    .cv__sub--solved {
        position: absolute;
        left: 0;
        right: 0;
    }

    .cv__title--problem {
        opacity: var(--gone);
    }

    .cv__title--solved {
        top: 0;
        color: var(--tan-light, #e0c49a);
        opacity: var(--solved);
        clip-path: inset(0 calc((1 - var(--solved)) * 100%) 0 0);
        text-shadow: 0 0 34px rgba(201, 168, 124, calc(var(--solved) * 0.4));
    }

    .cv__sub {
        font-family: var(--font-body, "DM Sans", sans-serif);
        font-size: clamp(0.95rem, 1.6vw, 1.1rem);
        line-height: 1.65;
        color: var(--muted, #888077);
        margin-top: 22px;
        max-width: 30ch;
        margin-inline: auto;
    }

    .cv__sub--problem { opacity: var(--gone); }
    .cv__sub--solved {
        margin-top: 0;
        transform: translateY(22px);
        color: var(--white, #f0ece4);
        opacity: var(--solved);
    }

    /* ── Convergence stage ── */
    .cv__stage {
        position: absolute;
        left: 50%;
        top: 58%;
        width: 0;
        height: 0;
        z-index: 2;
    }

    .cv__ring {
        position: absolute;
        left: 50%;
        top: 50%;
        border: 1px solid rgba(201, 168, 124, 0.18);
        border-radius: 50%;
        translate: -50% -50%;
        /* rings contract toward the bagel as you scroll */
        scale: calc(1 - var(--pull) * 0.55);
        opacity: calc((1 - var(--pull)) * 0.6);
    }

    .cv__ring--1 { width: 18vmin; height: 18vmin; }
    .cv__ring--2 { width: 32vmin; height: 32vmin; border-color: rgba(82, 183, 136, 0.16); }
    .cv__ring--3 { width: 48vmin; height: 48vmin; }

    .cv__bot {
        position: absolute;
        left: 50%;
        top: 50%;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 7px 13px;
        white-space: nowrap;
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.72rem;
        letter-spacing: 0.02em;
        color: var(--tan-light, #e0c49a);
        background: rgba(17, 17, 16, 0.82);
        border: 1px solid var(--border, rgba(201, 168, 124, 0.15));
        border-radius: var(--radius-pill, 100px);
        backdrop-filter: blur(4px);
        /* start scattered (--bx/--by vmin), get pulled to centre as --pull → 1 */
        translate:
            calc((var(--bx) * (1 - var(--pull))) * 1vmin - 50%)
            calc((var(--by) * (1 - var(--pull))) * 1vmin - 50%);
        scale: calc(1 - var(--pull) * 0.7);
        opacity: var(--gone);
        will-change: translate, scale, opacity;
    }

    .cv__bot-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green-glow, #52b788);
        box-shadow: 0 0 8px rgba(82, 183, 136, 0.7);
    }

    .cv__bagel {
        position: absolute;
        left: 50%;
        top: 50%;
        translate: -50% -50%;
        /* grows + ignites as the bots merge in */
        scale: calc(0.62 + var(--p, 0) * 0.7);
        filter: drop-shadow(0 0 calc(18px + var(--solved) * 46px) rgba(201, 168, 124, calc(0.25 + var(--solved) * 0.5)));
        will-change: scale, filter;
    }

    .cv__bagel :global(img) {
        width: clamp(76px, 13vmin, 120px);
        height: auto;
    }

    @media (prefers-reduced-motion: reduce) {
        .cv { height: auto; }
        .cv__pin { position: static; height: auto; padding: 96px 24px; gap: 32px; }
        .cv__head { margin-bottom: 0; }
        .cv__title--problem, .cv__sub--problem { display: none; }
        .cv__title--solved, .cv__sub--solved { position: static; opacity: 1; clip-path: none; transform: none; }
        .cv__stage { position: relative; left: auto; top: auto; width: auto; height: 200px; }
        .cv__bot { display: none; }
        .cv__bagel { position: static; translate: none; scale: 1; }
    }

    @media (max-width: 640px) {
        .cv { height: 360vh; }
        .cv__head { margin-bottom: clamp(220px, 40vh, 320px); }
        .cv__bot { font-size: 0.64rem; padding: 6px 10px; }
    }
</style>
