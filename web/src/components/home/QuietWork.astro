---
/**
 * QuietWork — a bento of the bot's chores, each card running its own tiny
 * live demo instead of a feature blurb. Built on the shared Card (spotlight +
 * lift); the demos are CSS loops, with one small script for the giveaway
 * name-shuffle and the poll bars (which want a reveal trigger).
 */
import Card from '../ui/Card.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import IncomingBadge from '../ui/IncomingBadge.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="qw" id="quiet-work">
    <SectionHeading eyebrow={t('qw.eyebrow')} title={t('qw.title')} />

    <div class="qw__grid">
        <!-- Govee: bulb lights up and washes the stage in chat's colour -->
        <Card class="qw__card qw__card--wide" data-reveal>
            <div class="qw__demo qw__demo--govee" aria-hidden="true">
                <span class="qw-govee__glow"></span>
                <span class="qw-govee__bulb">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 14c.2-1 .7-1.7 1.5-2.5C17.5 10.6 18 9.3 18 8A6 6 0 0 0 6 8c0 1.3.5 2.6 1.5 3.5.8.8 1.3 1.5 1.5 2.5" />
                        <path d="M9 18h6" />
                        <path d="M10 22h4" />
                        <path class="qw-govee__sprout" d="M12 15V9" />
                        <path class="qw-govee__sprout" d="M12 11c1.6 0 2.8-1.2 2.8-2.9-1.7 0-2.8 1.2-2.8 2.9Z" />
                        <path class="qw-govee__sprout" d="M12 12c-1.6 0-2.8-1.2-2.8-2.9 1.7 0 2.8 1.2 2.8 2.9Z" />
                    </svg>
                </span>
                <span class="qw-govee__redeem">
                    <span class="qw-govee__dot"></span>
                    {t('qw.goveeReward')}
                </span>
            </div>
            <h3 class="qw__title">{t('qw.goveeTitle')}</h3>
            <p class="qw__desc">{t('qw.goveeDesc')}</p>
        </Card>

        <!-- Commands: typewriter call + response -->
        <Card class="qw__card qw__card--wide" data-reveal style="--reveal-i: 1">
            <div class="qw__demo qw__demo--cmd" aria-hidden="true">
                <span class="qw-cmd__in">!welcome moth_lamp</span>
                <span class="qw-cmd__out">{t('qw.cmdOut')}</span>
            </div>
            <h3 class="qw__title">{t('qw.cmdTitle')}</h3>
            <p class="qw__desc">{t('qw.cmdDesc')}</p>
        </Card>

        <!-- Polls: racing bars, triggered on reveal -->
        <Card class="qw__card" data-reveal style="--reveal-i: 2">
            <div class="qw__demo qw__demo--poll" aria-hidden="true" data-qw-poll>
                <span class="qw-poll__bar"><i style="--w: 68%"></i><b>68%</b></span>
                <span class="qw-poll__bar"><i style="--w: 32%"></i><b>32%</b></span>
            </div>
            <h3 class="qw__title">
                {t('qw.pollTitle')}
                <IncomingBadge label={t('badge.incoming')} />
            </h3>
            <p class="qw__desc">{t('qw.pollDesc')}</p>
        </Card>

        <!-- Giveaways: name shuffle that lands -->
        <Card class="qw__card" data-reveal style="--reveal-i: 3">
            <div class="qw__demo qw__demo--win" aria-hidden="true">
                <span class="qw-win__label">{t('qw.winLabel')}</span>
                <span class="qw-win__name" data-qw-winner>night_owl_77</span>
            </div>
            <h3 class="qw__title">
                {t('qw.winTitle')}
                <IncomingBadge label={t('badge.incoming')} />
            </h3>
            <p class="qw__desc">{t('qw.winDesc')}</p>
        </Card>

        <!-- Always on: heartbeat -->
        <Card class="qw__card" data-reveal style="--reveal-i: 4">
            <div class="qw__demo qw__demo--beat" aria-hidden="true">
                <svg viewBox="0 0 120 32" preserveAspectRatio="none">
                    <path class="qw-beat__path" d="M0 16 H30 L38 16 L44 4 L52 28 L58 16 H82 L88 10 L94 22 L100 16 H120"
                          fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                </svg>
            </div>
            <h3 class="qw__title">{t('qw.beatTitle')}</h3>
            <p class="qw__desc">{t('qw.beatDesc')}</p>
        </Card>
    </div>
</section>

<style>
    .qw {
        position: relative;
        padding: var(--space-section, 96px) 24px;
        max-width: var(--content-max, 1200px);
        margin: 0 auto;
        z-index: 3;
    }

    .qw__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
    }

    @media (min-width: 720px) {
        .qw__grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (min-width: 1024px) {
        .qw__grid { grid-template-columns: repeat(6, 1fr); }
        .qw__card { grid-column: span 2; }
        .qw__card--wide { grid-column: span 3; }
    }

    .qw__title {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
        font-family: var(--font-display, "Syne", sans-serif);
        font-size: 1.06rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: var(--white, #f0ece4);
        margin: 0 0 8px;
    }

    .qw__desc {
        font-family: var(--font-body, "DM Sans", sans-serif);
        font-size: 0.86rem;
        line-height: 1.6;
        color: var(--muted, #888077);
        margin: 0;
    }

    /* ── Demo stage shared ── */

    .qw__demo {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 8px;
        height: 84px;
        margin-bottom: 20px;
        padding: 14px 16px;
        border-radius: 10px;
        background: rgba(10, 10, 10, 0.55);
        border: 1px solid rgba(240, 236, 228, 0.05);
        overflow: hidden;
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.74rem;
    }

    /* ── Govee: bulb wakes on redeem, light washes the stage ── */

    .qw__demo--govee {
        position: relative;
        flex-direction: row;
        align-items: center;
        gap: 16px;
        color: var(--green-glow, #52b788);
        animation: qwGoveeHue 9s ease-in-out infinite;
    }

    /* ambient spill from the bulb across the stage */
    .qw-govee__glow {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 38px 50%, currentColor, transparent 72%);
        opacity: 0.05;
        transform-origin: 38px 50%;
        animation: qwGoveeBloom 9s ease-in-out infinite;
        pointer-events: none;
    }

    .qw-govee__bulb {
        flex: none;
        display: grid;
        place-items: center;
        animation: qwGoveeLit 9s ease-in-out infinite;
    }

    .qw-govee__bulb svg { width: 44px; height: 44px; }

    /* the sprout stays green: efficient light, always alive */
    .qw-govee__sprout { stroke: var(--green-glow, #52b788); }

    .qw-govee__redeem {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--muted, #888077);
        opacity: 0;
        animation: qwGoveeRedeem 9s ease-in-out infinite;
    }

    .qw-govee__dot {
        flex: none;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
        box-shadow: 0 0 8px currentColor;
        color: var(--green-glow, #52b788);
        animation: qwGoveeHue 9s ease-in-out infinite;
    }

    /* off → redeem lands → warm sunset wash → eases back to dark */
    @keyframes qwGoveeHue {
        0%, 28%  { color: #5c665f; }
        40%, 50% { color: #52b788; }
        62%, 72% { color: #e0c49a; }
        82%      { color: #d98a8a; }
        100%     { color: #5c665f; }
    }

    @keyframes qwGoveeBloom {
        0%, 28%   { opacity: 0.05; transform: scale(0.85); }
        44%, 82%  { opacity: 0.3;  transform: scale(1); }
        100%      { opacity: 0.05; transform: scale(0.85); }
    }

    @keyframes qwGoveeLit {
        0%, 28%  { opacity: 0.5; filter: drop-shadow(0 0 0 transparent) drop-shadow(0 0 0 transparent); }
        44%, 82% { opacity: 1;   filter: drop-shadow(0 0 5px currentColor) drop-shadow(0 0 16px currentColor); }
        100%     { opacity: 0.5; filter: drop-shadow(0 0 0 transparent) drop-shadow(0 0 0 transparent); }
    }

    @keyframes qwGoveeRedeem {
        0%, 26%  { opacity: 0; transform: translateY(4px); }
        34%, 84% { opacity: 1; transform: none; }
        94%, 100% { opacity: 0; }
    }

    /* ── Commands: typewriter in, reply out ── */

    .qw-cmd__in {
        color: var(--tan-light, #e0c49a);
        width: 18ch;
        max-width: 100%;
        white-space: nowrap;
        overflow: hidden;
        border-right: 1px solid rgba(224, 196, 154, 0.6);
        animation: qwType 5.4s steps(18) infinite;
    }

    .qw-cmd__out {
        color: var(--green-glow, #52b788);
        opacity: 0;
        animation: qwCmdOut 5.4s ease-in-out infinite;
    }

    @keyframes qwType {
        0%, 6% { width: 0; }
        30%, 92% { width: 18ch; }
        97%, 100% { width: 0; }
    }

    @keyframes qwCmdOut {
        0%, 34% { opacity: 0; transform: translateY(4px); }
        44%, 88% { opacity: 1; transform: none; }
        96%, 100% { opacity: 0; }
    }



    /* ── Polls: bars fill when revealed ── */

    .qw-poll__bar {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: 8px;
    }

    .qw-poll__bar i {
        display: block;
        height: 7px;
        width: 4%;
        border-radius: 4px;
        background: linear-gradient(90deg, rgba(201, 168, 124, 0.5), var(--tan, #c9a87c));
        transition: width 1200ms var(--ease-out-expo);
    }

    .qw-poll__bar:nth-child(2) i {
        background: linear-gradient(90deg, rgba(82, 183, 136, 0.5), var(--green-glow, #52b788));
        transition-delay: 140ms;
    }

    .qw-poll__bar b {
        font-weight: 500;
        font-size: 0.68rem;
        color: var(--muted, #888077);
    }

    .qw__demo--poll.is-live .qw-poll__bar i { width: var(--w, 50%); }

    /* ── Giveaway winner ── */

    .qw__demo--win { align-items: flex-start; gap: 4px; }

    .qw-win__label {
        font-size: 0.62rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted, #888077);
    }

    .qw-win__name {
        font-size: 1rem;
        color: var(--tan-light, #e0c49a);
        text-shadow: 0 0 18px rgba(201, 168, 124, 0.35);
    }

    /* ── Heartbeat ── */

    .qw__demo--beat { color: var(--green-glow, #52b788); padding: 18px 12px; }

    .qw__demo--beat svg { width: 100%; height: 100%; overflow: visible; }

    .qw-beat__path {
        stroke-dasharray: 220;
        stroke-dashoffset: 220;
        filter: drop-shadow(0 0 6px rgba(82, 183, 136, 0.55));
        animation: qwBeat 3.2s linear infinite;
    }

    @keyframes qwBeat {
        0% { stroke-dashoffset: 220; opacity: 1; }
        62% { stroke-dashoffset: 0; opacity: 1; }
        78% { opacity: 0.25; }
        100% { stroke-dashoffset: 0; opacity: 0; }
    }

    @media (prefers-reduced-motion: reduce) {
        .qw__demo--govee, .qw-govee__glow, .qw-govee__bulb, .qw-govee__dot, .qw-govee__redeem,
        .qw-cmd__in, .qw-cmd__out,
        .qw-beat__path {
            animation: none;
        }
        .qw-govee__glow { opacity: 0.22; transform: none; }
        .qw-govee__bulb { opacity: 1; filter: drop-shadow(0 0 5px currentColor) drop-shadow(0 0 16px currentColor); }
        .qw-govee__redeem { opacity: 1; }
        .qw-cmd__in { width: 18ch; border-right: none; }
        .qw-cmd__out { opacity: 1; }
        .qw-beat__path { stroke-dashoffset: 0; }
        .qw-poll__bar i { transition: none; }
        .qw__demo--poll .qw-poll__bar i { width: var(--w, 50%); }
    }

    @media (max-width: 640px) {
        .qw { padding: var(--space-section-sm, 72px) 20px; }
    }
</style>

<script>
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    /* Poll bars fill the first time the card scrolls into view */
    function setupPolls() {
        const polls = document.querySelectorAll<HTMLElement>('[data-qw-poll]');
        if (!polls.length) return;
        const io = new IntersectionObserver((entries, obs) => {
            entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add('is-live');
                obs.unobserve(entry.target);
            });
        }, { threshold: 0.4 });
        polls.forEach((el) => io.observe(el));
    }

    /* Giveaway name shuffles, then lands. Loops slowly while visible. */
    const NAMES = ['night_owl_77', 'gg_beans', 'moth_lamp', 'soupdream', 'tiny_cactus', 'pixel_pal'];
    const GLYPHS = 'abcdefghijklmnopqrstuvwxyz_0123456789';

    function shuffleTo(el: HTMLElement, name: string) {
        const start = performance.now();
        const duration = 900;
        function tick(now: number) {
            const p = Math.min(1, (now - start) / duration);
            const reveal = Math.floor(name.length * p);
            el.textContent = name
                .split('')
                .map((ch, i) => (i < reveal ? ch : GLYPHS[Math.floor(Math.random() * GLYPHS.length)]))
                .join('');
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = name;
        }
        requestAnimationFrame(tick);
    }

    function setupWinners() {
        document.querySelectorAll<HTMLElement>('[data-qw-winner]').forEach((el) => {
            if (el.dataset.qwReady === 'true') return;
            el.dataset.qwReady = 'true';
            if (reduceMotion.matches) return;

            let visible = false;
            let i = 0;
            let timer = 0;

            function loop() {
                window.clearTimeout(timer);
                if (!visible || document.hidden) return;
                shuffleTo(el, NAMES[i++ % NAMES.length]);
                timer = window.setTimeout(loop, 4200);
            }

            const io = new IntersectionObserver(([entry]) => {
                visible = entry.isIntersecting;
                if (visible) loop();
                else window.clearTimeout(timer);
            }, { rootMargin: '40px' });
            io.observe(el);
        });
    }

    function setup() {
        setupPolls();
        setupWinners();
    }

    setup();
    document.addEventListener('astro:page-load', setup);
</script>
