---
/**
 * Letter — the human beat of the page. A short unsigned-at-2 a.m. note from
 * the people building the bot, set on a slightly tilted "paper" card. The
 * signature uses the handwriting face; the stamp sprinkles sesame seeds
 * (reusing the global .sesame-seed easter-egg styles) when clicked.
 */
import { getLangFromUrl, useTranslations } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="letter" id="letter">
    <div class="letter__paper" data-reveal>
        <div class="letter__meta">
            <span>notes.txt</span>
            <span>{t('letter.meta2')}</span>
        </div>

        <p class="letter__line">
            {t('letter.line1')}
        </p>

        <p class="letter__line">
            {t('letter.line2')}
        </p>

        <p class="letter__line">
            {t('letter.line3')}
        </p>

        <div class="letter__sign">
            <span class="letter__signature">{t('letter.signature')}</span>
            <button type="button" class="letter__stamp" data-letter-stamp aria-label={t('letter.stampAria')}>
                🥯
            </button>
        </div>

        <span class="letter__ps">{t('letter.ps')}</span>
    </div>
</section>

<style>
    .letter {
        position: relative;
        padding: var(--space-section, 96px) 24px;
        max-width: none;
        margin: 0;
        z-index: 3;
        display: flex;
        justify-content: center;
        overflow: hidden;
    }

    .letter::before {
        content: "";
        position: absolute;
        left: 50%;
        top: 50%;
        width: 100vmin;
        height: 80vmin;
        translate: -50% -50%;
        pointer-events: none;
        background: radial-gradient(
            50% 55% at 50% 50%,
            rgba(201, 168, 124, 0.1) 0%,
            transparent 70%
        );
        filter: blur(14px);
    }

    .letter__paper {
        position: relative;
        width: min(560px, 100%);
        background: linear-gradient(160deg, #141412, #101010);
        border: 1px solid rgba(201, 168, 124, 0.2);
        border-radius: 14px;
        padding: clamp(28px, 5vw, 48px);
        rotate: -0.6deg;
        box-shadow:
            0 30px 80px rgba(0, 0, 0, 0.55),
            inset 0 1px 0 rgba(240, 236, 228, 0.04);
        transition: rotate 480ms var(--ease-out-expo), box-shadow 480ms var(--ease-out-expo);
    }

    @media (hover: hover) and (pointer: fine) {
        .letter__paper:hover {
            rotate: 0deg;
            box-shadow:
                0 36px 90px rgba(0, 0, 0, 0.6),
                0 0 60px rgba(201, 168, 124, 0.07),
                inset 0 1px 0 rgba(240, 236, 228, 0.05);
        }
    }

    .letter__meta {
        display: flex;
        justify-content: space-between;
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        color: var(--muted, #888077);
        border-bottom: 1px dashed rgba(201, 168, 124, 0.18);
        padding-bottom: 14px;
        margin-bottom: 26px;
    }

    .letter__line {
        font-family: var(--font-body, "DM Sans", sans-serif);
        font-size: clamp(0.95rem, 1.6vw, 1.05rem);
        line-height: 1.8;
        color: rgba(240, 236, 228, 0.82);
        margin: 0 0 20px;
    }

    .letter__sign {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-top: 32px;
    }

    .letter__signature {
        position: relative;
        font-family: var(--font-hand, "Caveat", cursive);
        font-size: clamp(1.5rem, 3.4vw, 1.9rem);
        font-weight: 600;
        color: var(--tan-light, #e0c49a);
        line-height: 1;
    }

    /* Ink underline draws on reveal */
    .letter__signature::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -8px;
        width: 100%;
        height: 2px;
        border-radius: 2px;
        background: linear-gradient(90deg, rgba(201, 168, 124, 0.7), rgba(82, 183, 136, 0.5));
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 900ms var(--ease-out-expo) 600ms;
    }

    .letter__paper.is-revealed .letter__signature::after {
        transform: scaleX(1);
    }

    .letter__stamp {
        flex-shrink: 0;
        display: grid;
        place-items: center;
        width: 58px;
        height: 58px;
        font-size: 1.5rem;
        border-radius: 50%;
        border: 1.5px dashed rgba(201, 168, 124, 0.4);
        rotate: 8deg;
        cursor: pointer;
        transition: rotate 380ms var(--ease-out-back, cubic-bezier(0.34, 1.56, 0.64, 1)),
                    border-color 240ms ease,
                    background 240ms ease;
    }

    @media (hover: hover) and (pointer: fine) {
        .letter__stamp:hover {
            rotate: -6deg;
            border-color: rgba(201, 168, 124, 0.7);
            background: rgba(201, 168, 124, 0.06);
        }
    }

    .letter__stamp:active { rotate: 14deg; }

    .letter__stamp.is-stamped {
        animation: stampPress 420ms var(--ease-out-back);
    }

    @keyframes stampPress {
        0% { scale: 1; }
        40% { scale: 0.82; }
        100% { scale: 1; }
    }

    .letter__ps {
        display: block;
        margin-top: 26px;
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.68rem;
        letter-spacing: 0.06em;
        color: var(--muted, #888077);
        opacity: 0.7;
    }

    @media (prefers-reduced-motion: reduce) {
        .letter__paper { rotate: 0deg; transition: none; }
        .letter__signature::after { transform: scaleX(1); transition: none; }
        .letter__stamp { transition: none; }
        .letter__stamp.is-stamped { animation: none; }
    }
</style>

<script>
    /* Stamp click → sesame burst. Reuses the global .sesame-seed styles. */
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    function sprinkle(x: number, y: number) {
        if (reduceMotion.matches) return;
        const count = 10 + Math.floor(Math.random() * 6);
        for (let i = 0; i < count; i++) {
            const seed = document.createElement('span');
            seed.className = 'sesame-seed';
            seed.style.left = `${x + (Math.random() - 0.5) * 70}px`;
            seed.style.top = `${y + (Math.random() - 0.5) * 70}px`;
            seed.style.setProperty('--rot', `${Math.floor(Math.random() * 360)}deg`);
            document.body.appendChild(seed);
            window.setTimeout(() => seed.remove(), 1100);
        }
    }

    function setup() {
        document.querySelectorAll<HTMLButtonElement>('[data-letter-stamp]').forEach((stamp) => {
            if (stamp.dataset.stampReady === 'true') return;
            stamp.dataset.stampReady = 'true';
            stamp.addEventListener('click', (event) => {
                stamp.classList.remove('is-stamped');
                void stamp.offsetWidth; /* restart the press animation */
                stamp.classList.add('is-stamped');
                sprinkle(event.clientX || 0, event.clientY || 0);
            });
        });
    }

    setup();
    document.addEventListener('astro:page-load', setup);
</script>
