---
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';

interface Feature {
    icon: string;
    title: string;
    description: string;
}

const features: Feature[] = [
    {
        icon: 'shield',
        title: 'Chat Moderation',
        description: 'Automated filters catch spam, hate speech, and rule violations before they reach your chat. Configurable sensitivity and custom word lists.',
    },
    {
        icon: 'terminal',
        title: 'Custom Commands',
        description: 'Build dynamic commands with variables, cooldowns, and permission levels. From simple text responses to complex API-driven outputs.',
    },
    {
        icon: 'music',
        title: 'Song Requests',
        description: 'Let viewers queue songs with built-in duplicate detection, skip voting, and volume normalization. Supports major platforms.',
    },
    {
        icon: 'chart',
        title: 'Polls & Giveaways',
        description: 'Engage your audience with real-time polls, timed giveaways, and loyalty-based entries. Fair, transparent, and fully logged.',
    },
    {
        icon: 'graph',
        title: 'Analytics Dashboard',
        description: 'Track chat activity, moderation events, and viewer engagement. Exportable data with historical trending.',
    },
    {
        icon: 'lock',
        title: 'Privacy-First',
        description: 'No tracking pixels, no data selling, no third-party analytics. Your data stays on your infrastructure. Source available.',
    },
];
---

<section id="features">
    <SectionHeading eyebrow="What You Get" title="Everything your stream needs." />

    <div class="features-grid">
        {features.map((feature, i) => (
            <Card as="div" class="feature-card" data-reveal style={`--reveal-i: ${i}`}>
                <div class="feature-card__icon">
                    {feature.icon === 'shield' && (
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                            <path d="M9 12l2 2 4-4" />
                        </svg>
                    )}
                    {feature.icon === 'terminal' && (
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="4 17 10 11 4 5" />
                            <line x1="12" y1="19" x2="20" y2="19" />
                        </svg>
                    )}
                    {feature.icon === 'music' && (
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 18V5l12-2v13" />
                            <circle cx="6" cy="18" r="3" />
                            <circle cx="18" cy="16" r="3" />
                        </svg>
                    )}
                    {feature.icon === 'chart' && (
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="20" x2="18" y2="10" />
                            <line x1="12" y1="20" x2="12" y2="4" />
                            <line x1="6" y1="20" x2="6" y2="14" />
                        </svg>
                    )}
                    {feature.icon === 'graph' && (
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2" />
                            <path d="M7 17l4-6 3 3 3-5" />
                            <circle cx="17" cy="9" r="1.5" />
                        </svg>
                    )}
                    {feature.icon === 'lock' && (
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            <circle cx="12" cy="16" r="1" />
                        </svg>
                    )}
                </div>
                <h3 class="feature-card__title">{feature.title}</h3>
                <p class="feature-card__desc">{feature.description}</p>
            </Card>
        ))}
    </div>
</section>

<style>
    section {
        padding: 100px 48px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .features-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
    }

    .feature-card__icon {
        color: var(--green-glow, #52b788);
        margin-bottom: 20px;
        line-height: 0;
    }

    .feature-card__title {
        font-family: var(--font-display, "Syne", sans-serif);
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--white, #f0ece4);
        margin-bottom: 10px;
        letter-spacing: -0.01em;
    }

    .feature-card__desc {
        font-family: var(--font-body, "DM Sans", sans-serif);
        font-size: 0.92rem;
        line-height: 1.65;
        color: var(--muted, #888077);
        margin: 0;
    }

    @media (min-width: 640px) {
        .features-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 900px) {
        .features-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }
    }

    @media (max-width: 640px) {
        section {
            padding: 72px 24px;
        }

        .feature-card__title {
            font-size: 1rem;
        }

        .feature-card__desc {
            font-size: 0.88rem;
        }
    }

    @media (max-width: 480px) {
        section {
            padding: 60px 18px;
        }
    }
</style>
