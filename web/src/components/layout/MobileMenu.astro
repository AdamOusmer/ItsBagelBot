---
interface Props {
    links: { href: string; label: string }[];
    ctaHref?: string;
    ctaLabel?: string;
}

const { links, ctaHref = "#", ctaLabel = "Add to Twitch" } = Astro.props;
---

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <ul class="mobile-menu__links">
        {links.map((link) => (
            <li><a class="mobile-menu__link" href={link.href}>{link.label}</a></li>
        ))}
    </ul>

    <div class="mobile-menu__footer">
        <a class="mobile-menu__cta" href={ctaHref}>{ctaLabel}</a>
        <span class="mobile-menu__meta">Freshly baked for Twitch chat</span>
    </div>
</div>

<style>
    .mobile-menu {
        display: none;
        position: fixed;
        inset: 0;
        padding: calc(10vh + 32px) 8vw 8vh;
        background: rgba(10, 10, 10, 0.96);
        backdrop-filter: blur(22px);
        -webkit-backdrop-filter: blur(22px);
        z-index: 49;
        flex-direction: column;
        justify-content: space-between;
        gap: 40px;
        overflow-y: auto;

        opacity: 0;
        pointer-events: none;
        transition: opacity 320ms ease;
    }

    .mobile-menu.is-open {
        opacity: 1;
        pointer-events: auto;
    }

    /* ─── Links ─── */
    .mobile-menu__links {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .mobile-menu__link {
        display: block;
        font-family: var(--font-display, "Syne", sans-serif);
        font-weight: 700;
        font-size: clamp(2rem, 9vw, 3.2rem);
        line-height: 1.2;
        letter-spacing: -0.025em;
        color: var(--white, #f0ece4);
        text-decoration: none;
        padding: 6px 0;

        opacity: 0;
        transform: translateY(18px);
        transition: opacity 380ms ease, transform 380ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .mobile-menu__link:active { color: var(--green-glow, #52b788); }

    .mobile-menu.is-open .mobile-menu__link {
        opacity: 1;
        transform: translateY(0);
    }

    /* Stagger reveal */
    .mobile-menu.is-open li:nth-child(1) .mobile-menu__link { transition-delay: 100ms; }
    .mobile-menu.is-open li:nth-child(2) .mobile-menu__link { transition-delay: 160ms; }
    .mobile-menu.is-open li:nth-child(3) .mobile-menu__link { transition-delay: 220ms; }
    .mobile-menu.is-open li:nth-child(4) .mobile-menu__link { transition-delay: 280ms; }
    .mobile-menu.is-open li:nth-child(5) .mobile-menu__link { transition-delay: 340ms; }

    /* ─── Footer ─── */
    .mobile-menu__footer {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-top: 24px;
        border-top: 1px solid rgba(201, 168, 124, 0.15);

        opacity: 0;
        transform: translateY(12px);
        transition: opacity 380ms ease 360ms, transform 380ms cubic-bezier(0.16, 1, 0.3, 1) 360ms;
    }

    .mobile-menu.is-open .mobile-menu__footer {
        opacity: 1;
        transform: translateY(0);
    }

    .mobile-menu__cta {
        display: block;
        text-align: center;
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.85rem;
        padding: 16px 24px;
        background: transparent;
        border: 1px solid var(--tan, #c9a87c);
        color: var(--tan-light, #e0c49a);
        border-radius: 6px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        transition: background 200ms ease, color 200ms ease;
    }

    .mobile-menu__cta:active {
        background: var(--tan, #c9a87c);
        color: var(--black, #0a0a0a);
    }

    .mobile-menu__meta {
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted, #888077);
        text-align: center;
    }

    @media (max-width: 900px) {
        .mobile-menu { display: flex; }
    }
</style>
