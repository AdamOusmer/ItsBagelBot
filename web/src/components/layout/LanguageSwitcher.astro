---
/**
 * Locale toggle. One option per discovered locale; each links to the current
 * page's equivalent in that locale. Routes without a translated counterpart
 * fall back to the default locale so the switcher never creates a dead link.
 */
import { getLangFromUrl, LOCALIZED_PATHS, localizePath, splitLocale, locales, defaultLang, type Lang } from '../../i18n/ui';

const current = getLangFromUrl(Astro.url);
const { path } = splitLocale(Astro.url.pathname);

function localePath(target: Lang): string {
  if (target === defaultLang) return path;
  if (!LOCALIZED_PATHS.has(path)) return path; // no translated route → keep default path
  return localizePath(path, target);
}

const options: readonly Lang[] = locales;
---

<div class="lang-switch" role="group" aria-label="Language">
  {options.map((l) => (
    <a
      href={localePath(l)}
      hreflang={l}
      class:list={['lang-switch__opt', { 'is-active': l === current }]}
      aria-current={l === current ? 'true' : undefined}
    >{l.toUpperCase()}</a>
  ))}
</div>

<style>
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 3px;
    border: 1px solid var(--border);
    border-radius: 999px;
  }

  .lang-switch__opt {
    font-family: var(--font-mono, "DM Mono", monospace);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--muted);
    text-decoration: none;
    padding: 4px 9px;
    border-radius: 999px;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .lang-switch__opt:hover { color: var(--tan-light); }

  .lang-switch__opt.is-active {
    color: var(--black, #0a0a0a);
    background: var(--tan, #c9a87c);
  }
</style>
