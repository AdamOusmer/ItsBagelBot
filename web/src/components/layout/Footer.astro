---
import { Image } from 'astro:assets';
import logoImage from '../../assets/LogoBOT.png';
---

<footer>
    <div class="top">
        <div class="brand" data-reveal>
            <Image src={logoImage} alt="ItsBagelBot Logo" width={55} height={55} fetchpriority="high" />
            <div>
                <span class="name">ItsBagelBot</span>
                <span class="tagline">Your stream. Your rules.</span>
            </div>
        </div>

        <div class="cols">
            <div class="col" data-reveal style="--reveal-i: 1">
                <p>Product</p>
                <a href="/pricing">Pricing</a>
                <a href="https://docs.itsbagelbot.com" target="_blank" rel="noopener noreferrer">Documentation</a>
                <a href="https://dashboard.itsbagelbot.com" target="_blank" rel="noopener noreferrer">Dashboard</a>
            </div>
            <div class="col" data-reveal style="--reveal-i: 2">
                <p>Company</p>
                <a href="/contact">Contact</a>
                <a href="https://github.com/AdamOusmer/ItsBagelBot" target="_blank" rel="noopener noreferrer">GitHub</a>
            </div>
            <div class="col" data-reveal style="--reveal-i: 3">
                <p>Community</p>
                <a href="https://discord.gg/SZ2remwSDv" target="_blank" rel="noopener noreferrer">Discord</a>
                <a href="https://twitch.tv/itsbagelbot" target="_blank" rel="noopener noreferrer">Twitch</a>
            </div>
        </div>
    </div>

    <div class="bottom">
        <span class="copy">&copy; 2026 ItsBagelBot</span>
        <span class="note">No data sold &middot; No trackers &middot; No surprises</span>
        <div class="legal">
            <a href="/privacy">Privacy Policy</a>
            <a href="/terms">Terms of Service</a>
        </div>
    </div>
</footer>

<style>
    footer {
        border-top: 1px solid var(--border);
        padding: 64px 4% 40px;
    }

    .top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 60px;
        margin-bottom: 60px;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .brand div {
        display: flex;
        flex-direction: column;
    }

    .name {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--white);
        margin-bottom: 10px;
    }

    .tagline {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--muted);
        letter-spacing: 0.05em;
    }

    .cols {
        display: flex;
        gap: 60px;
    }

    .col {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .col p {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        letter-spacing: 0.10em;
        text-transform: uppercase;
        color: var(--white);
        margin: 0 0 4px 0;
    }

    .col a {
        width: fit-content;
        font-size: 0.85rem;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.2s var(--ease-out-expo), transform 0.3s var(--ease-out-expo);
    }

    .col a:hover {
        color: var(--tan-light);
        transform: translateX(4px);
    }

    @media (prefers-reduced-motion: reduce) {
        .col a:hover {
            transform: none;
        }
    }

    .bottom {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        padding-top: 30px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .copy {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--muted);
        letter-spacing: 0.06em;
    }

    .note {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--muted);
        letter-spacing: 0.08em;
    }

    .legal {
        display: flex;
        justify-content: flex-end;
        gap: 20px;
    }

    .legal a {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: color 0.2s;
    }

    .legal a:hover {
        color: var(--tan-light);
    }

    @media (max-width: 900px) {
        footer {
            padding: 50px 25px 30px;
        }

        .top {
            flex-direction: column;
            gap: 40px;
        }

        .cols {
            flex-wrap: wrap;
            gap: 30px;
        }

        .bottom {
            grid-template-columns: 1fr;
            gap: 10px;
            text-align: center;
        }

        .legal {
            justify-content: center;
        }
    }
</style>