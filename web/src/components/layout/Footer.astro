---
/**
 * Footer — the sign-off. A big warm goodbye line, the usual columns, and a
 * bottom strip that repeats the only promise that matters. The logo does a
 * little wobble when you catch it.
 */
import { Image } from 'astro:assets';
import logoImage from '../../assets/LogoBOT.png';
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer>
    <div class="signoff" data-reveal>
        <p class="signoff__line">{t('footer.signoff')}</p>
        <p class="signoff__sub">{t('footer.signoffSub')}</p>
    </div>

    <div class="top">
        <div class="brand" data-reveal>
            <span class="brand__logo">
                <Image src={logoImage} alt="ItsBagelBot Logo" width={55} height={55} fetchpriority="high" />
            </span>
            <div>
                <span class="name">ItsBagelBot</span>
                <span class="tagline">{t('footer.tagline')}</span>
            </div>
        </div>

        <div class="cols">
            <div class="col" data-reveal style="--reveal-i: 1">
                <p>{t('footer.product')}</p>
                <a href={localizePath("/pricing", lang)}>{t('footer.pricing')}</a>
                <a href="https://docs.itsbagelbot.com" target="_blank" rel="noopener noreferrer">{t('footer.docs')}</a>
                <a href="https://dashboard.itsbagelbot.com" target="_blank" rel="noopener noreferrer">{t('footer.dashboard')}</a>
            </div>
            <div class="col" data-reveal style="--reveal-i: 2">
                <p>{t('footer.company')}</p>
                <a href={localizePath("/contact", lang)}>{t('footer.contact')}</a>
                <a href="https://github.com/AdamOusmer/ItsBagelBot" target="_blank" rel="noopener noreferrer">GitHub</a>
            </div>
            <div class="col" data-reveal style="--reveal-i: 3">
                <p>{t('footer.community')}</p>
                <a href="https://discord.gg/SZ2remwSDv" target="_blank" rel="noopener noreferrer">Discord</a>
                <a href="https://twitch.tv/itsbagelbot" target="_blank" rel="noopener noreferrer">Twitch</a>
            </div>
        </div>
    </div>

    <div class="bottom">
        <span class="copy">&copy; 2026 ItsBagelBot</span>
        <span class="note">{t('footer.note')}</span>
        <div class="legal">
            <a href="/privacy">{t('footer.privacy')}</a>
            <a href="/terms">{t('footer.terms')}</a>
        </div>
    </div>
</footer>

<style>
    footer {
        position: relative;
        border-top: 1px solid var(--border);
        padding: 72px 4% 40px;
        overflow: hidden;
    }

    /* Faint hearth ember behind the sign-off */
    footer::before {
        content: "";
        position: absolute;
        left: 50%;
        top: 0;
        width: 90vmin;
        height: 40vmin;
        translate: -50% -50%;
        pointer-events: none;
        background: radial-gradient(
            50% 60% at 50% 50%,
            rgba(201, 168, 124, 0.09) 0%,
            transparent 70%
        );
        filter: blur(12px);
    }

    /* ── Sign-off ── */

    .signoff {
        position: relative;
        text-align: center;
        margin-bottom: 72px;
    }

    .signoff__line {
        font-family: var(--font-display);
        font-weight: 800;
        font-size: clamp(1.7rem, 4.6vw, 2.9rem);
        letter-spacing: -0.02em;
        line-height: 1.08;
        color: var(--white);
        margin: 0 0 10px;
        text-shadow: 0 0 30px rgba(201, 168, 124, 0.16);
    }

    .signoff__sub {
        font-family: var(--font-hand, "Caveat", cursive);
        font-size: clamp(1.2rem, 2.6vw, 1.5rem);
        font-weight: 500;
        color: var(--tan-light);
        margin: 0;
        rotate: -1deg;
    }

    /* ── Top ── */

    .top {
        position: relative;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 60px;
        margin-bottom: 60px;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .brand__logo {
        display: inline-block;
        line-height: 0;
        transition: rotate 500ms var(--ease-out-back, cubic-bezier(0.34, 1.56, 0.64, 1));
    }

    @media (hover: hover) and (pointer: fine) {
        .brand:hover .brand__logo { rotate: 14deg; }
    }

    .brand div {
        display: flex;
        flex-direction: column;
    }

    .name {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--white);
        margin-bottom: 10px;
    }

    .tagline {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--muted);
        letter-spacing: 0.05em;
    }

    .cols {
        display: flex;
        gap: 60px;
    }

    .col {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .col p {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        letter-spacing: 0.10em;
        text-transform: uppercase;
        color: var(--white);
        margin: 0 0 4px 0;
    }

    .col a {
        position: relative;
        width: fit-content;
        font-size: 0.85rem;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.2s var(--ease-out-expo), transform 0.3s var(--ease-out-expo);
    }

    /* Little ember dot slides in ahead of the label */
    .col a::before {
        content: "";
        position: absolute;
        left: -12px;
        top: 50%;
        width: 4px;
        height: 4px;
        border-radius: 50%;
        translate: 0 -50%;
        background: var(--tan);
        opacity: 0;
        scale: 0;
        transition: opacity 0.25s ease, scale 0.3s var(--ease-out-back, cubic-bezier(0.34, 1.56, 0.64, 1));
    }

    .col a:hover {
        color: var(--tan-light);
        transform: translateX(6px);
    }

    .col a:hover::before {
        opacity: 1;
        scale: 1;
    }

    @media (prefers-reduced-motion: reduce) {
        .col a:hover { transform: none; }
        .col a::before { display: none; }
        .brand__logo { transition: none; }
    }

    /* ── Bottom ── */

    .bottom {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        padding-top: 30px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .copy {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--muted);
        letter-spacing: 0.06em;
    }

    .note {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--muted);
        letter-spacing: 0.08em;
    }

    .legal {
        display: flex;
        justify-content: flex-end;
        gap: 20px;
    }

    .legal a {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: color 0.2s;
    }

    .legal a:hover {
        color: var(--tan-light);
    }

    @media (max-width: 900px) {
        footer {
            padding: 56px 25px 30px;
        }

        .signoff { margin-bottom: 56px; }

        .top {
            flex-direction: column;
            gap: 40px;
        }

        .cols {
            flex-wrap: wrap;
            gap: 30px;
        }

        .bottom {
            grid-template-columns: 1fr;
            gap: 10px;
            text-align: center;
        }

        .legal {
            justify-content: center;
        }
    }
</style>
