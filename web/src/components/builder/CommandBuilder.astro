        .vars, .more-grid { grid-template-columns: 1fr; }
        .f-name { max-width: none; }
        .mode-seg { width: 100%; }
        .mode-seg button { flex: 1; justify-content: center; }
    }

    @media (prefers-reduced-motion: reduce) {
