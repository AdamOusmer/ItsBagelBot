---
/**
 * CommandBuilder — the interactive command workbench. Non-technical streamers
 * compose a command (or a module reply) by clicking variables instead of
 * memorizing syntax, watch a live chat rehearsal, then either send the result
 * straight into the dashboard's command editor (deep link, pre-filled) or
 * copy it as a !cmd chat line / template.
 *
 * Layout is deliberately two zones: one compose card (essentials on top,
 * access/cooldown/aliases folded into "More options") and a slim aside with
 * the rehearsal and a single action card — one primary CTA, the chat-paste
 * path secondary beneath it.
 *
 * The rehearsal is a straight port of the dashboard inspector's ChatPreview
 * (console/dashboard/src/lib/components/commands/ChatPreview.svelte): same
 * typing beat, same staggered reply-in animation, same announcement /
 * shoutout / pin / me styling and sample-value highlights — the builder is
 * meant to feel like the dashboard reaching out onto the marketing site.
 *
 * All copy and the variable catalog come from src/i18n/builder.ts (both
 * locales), which mirrors what the bot actually expands. Runtime strings reach
 * the client through a JSON island (site pattern, CSP-safe); the client script
 * builds DOM with textContent only.
 */
import logoImage from '../../assets/LogoBOT.png';
import { builderData, builderUI } from '../../i18n/builder';
import type { Lang } from '../../i18n/ui';

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const data = builderData(lang);
const ui = builderUI(lang);
const guideHref = lang === 'fr' ? '/fr/guides/commands' : '/guides/commands';

// Grouped surfaces for the module <select>, custom excluded (it's a mode).
const groups: { group: string; items: { id: string; label: string }[] }[] = [];
for (const surface of data.surfaces) {
    if (surface.id === 'custom') continue;
    const bucket = groups.find((g) => g.group === surface.group);
    if (bucket) bucket.items.push({ id: surface.id, label: surface.label });
    else groups.push({ group: surface.group, items: [{ id: surface.id, label: surface.label }] });
}
---

<div class="builder" data-builder>
    <div class="layout">
        <main class="compose card">
            <div class="mode-row">
                <div class="mode-seg" role="group" aria-label={ui.step1Title}>
                    <button class="active" type="button" data-mode="custom" aria-pressed="true"><i>!</i>{ui.modeCustom}</button>
                    <button type="button" data-mode="module" aria-pressed="false"><i>&#123;&#125;</i>{ui.modeModule}</button>
                </div>
            </div>

            <label class="module-pick" hidden data-module-pick>{ui.surfaceLabel}
                <select data-surface>
                    {groups.map((g) => (
                        <optgroup label={g.group}>
                            {g.items.map((item) => <option value={item.id}>{item.label}</option>)}
                        </optgroup>
                    ))}
                </select>
                <small data-hint></small>
            </label>

            <div data-command-fields>
                <label class="f-name">{ui.nameLabel}
                    <span class="f-wrap"><span class="prefix">!</span><input value="welcome" maxlength="64" data-name /></span>
                    <small>{ui.nameHint}</small>
                </label>
            </div>

            <label class="response">{ui.responseLabel} <small><b data-count>0</b>/500</small><textarea rows="4" data-template></textarea></label>
            <div class="recipes" data-recipes><span>{ui.recipesLabel}</span></div>

            <section class="palette">
                <header><b>{ui.step3Title}</b><span class="scope" data-scope></span></header>
                <p class="palette-sub">{ui.step3Sub}</p>
                <div class="vars" data-vars aria-live="polite"></div>
                <details><summary>{ui.bracesSummary}</summary><p>{ui.bracesBody}</p></details>
            </section>

            <details class="more" data-more>
                <summary>{ui.moreOptions}</summary>
                <div class="more-grid">
                    <label class="span2">{ui.aliasLabel}<input placeholder="hi, heya" data-aliases /><small>{ui.aliasHint}</small></label>
                    <label>{ui.permLabel}
                        <select data-perm>
                            {data.perms.map((p) => <option value={p.value}>{p.label}</option>)}
                        </select>
                    </label>
                    <label>{ui.cooldownLabel}<input type="number" min="0" max="86400" value="0" data-cooldown /><small>{ui.cooldownHint}</small></label>
                    <label class="span2">{ui.styleLabel}
                        <select data-style>
                            {data.styles.map((s) => <option value={s.value}>{s.label}</option>)}
                        </select>
                    </label>
                </div>
            </details>
        </main>

        <aside>
            <section class="preview card">
                <header><b><i></i> {ui.previewTitle}</b><span data-context></span></header>
                <div class="chat" data-chat data-avatar={logoImage.src} aria-live="polite">
                    <span class="chat-tag" data-chat-tag>{ui.rehearsal}</span>
                </div>
                <small data-preview-note></small>
            </section>

            <section class="action card">
                <header><span data-action-title>{ui.sendTitle}</span><b data-valid>{ui.statusReady}</b></header>
                <div class="send" data-send-wrap>
                    <a class="send__cta" data-send target="_blank" rel="noopener noreferrer" href={data.dashboardOrigin + '/commands'}>
                        <span>{ui.sendCta}</span><b aria-hidden="true">→</b>
                    </a>
                    <p class="send__help">{ui.sendHelp}</p>
                </div>
                <div class="copyw" data-copy-wrap>
                    <p class="copyw__label" data-copy-title>{ui.copyTitleCustom}</p>
                    <pre data-output></pre>
                    <button type="button" data-copy><span>{ui.copyCta}</span></button>
                    <a class="copyw__module-link" data-module-link hidden target="_blank" rel="noopener noreferrer" href={data.dashboardOrigin}>{ui.openModule} →</a>
                </div>
            </section>
        </aside>
    </div>

    <p class="learn">
        {ui.learnMore} <a href={guideHref}>{ui.learnMoreCta} →</a>
    </p>

    <script type="application/json" data-builder-json set:html={JSON.stringify({
        data,
        ui: {
            statusReady: ui.statusReady,
            statusName: ui.statusName,
            statusLines: ui.statusLines,
            statusLineLen: ui.statusLineLen,
            statusEmpty: ui.statusEmpty,
            copied: ui.copied,
            copyFail: ui.copyFail,
            copyCta: ui.copyCta,
            sendTitle: ui.sendTitle,
            copyTitleCustom: ui.copyTitleCustom,
            copyTitleModule: ui.copyTitleModule,
            copyBodyModule: ui.copyBodyModule,
            // Rehearsal chrome, word-for-word the dashboard's chatPreview strings.
            rehearsal: ui.rehearsal,
            ariaTyping: ui.ariaTyping,
            announcement: ui.announcement,
            addMessageAfter: ui.addMessageAfter,
            shoutsOut: ui.shoutsOut,
            nameChannel: ui.nameChannel,
            pinnedForStream: ui.pinnedForStream,
            addActionAfterMe: ui.addActionAfterMe,
            nothingToSay: ui.nothingToSay,
            unknownVar: ui.unknownVar,
            recipes: lang === 'fr'
                ? [
                    { label: 'Accueillir quelqu’un', text: 'Bienvenue, {user}! Installe-toi 🥯' },
                    { label: 'Lancer un dé', text: '{user} lance {random:1-100} sur 100.' },
                    { label: 'Choisir une option', text: 'Ambiance du soir: {choice:cosy,chaotique,compétitive}.' },
                    { label: 'Compter les chutes', text: '{channel} est tombé {counter:chutes} fois.' },
                  ]
                : [
                    { label: 'Welcome someone', text: 'Welcome in, {user}! Grab a seat 🥯' },
                    { label: 'Roll a number', text: '{user} rolled {random:1-100} out of 100.' },
                    { label: 'Pick an option', text: "Tonight's vibe: {choice:cozy,chaotic,competitive}." },
                    { label: 'Count the falls', text: '{channel} has fallen {counter:falls} times.' },
                  ],
        },
    })} />
</div>

<script>
    type Var = { token: string; sample: string; name: string; desc: string };
    type Surface = { id: string; group: string; label: string; dashPath: string; hint: string; example: string; prompt: string; vars: Var[] };
    type Payload = {
        data: {
            lang: string;
            limits: { nameMax: number; aliasMax: number; lineMax: number; linesMax: number; cooldownMax: number };
            dashboardOrigin: string;
            perms: { value: string; label: string }[];
            styles: { value: string; label: string }[];
            surfaces: Surface[];
        };
        ui: Record<string, string> & { recipes: { label: string; text: string }[] };
    };

    // --- Slash-verb parse, same tables as the dashboard's ChatPreview (which
    // itself mirrors app/sesame/engine/slash.go). ---------------------------
    type Mode = 'chat' | 'announce' | 'shoutout' | 'pin' | 'me';
    type Parsed = { mode: Mode; body: string; verb?: string; color?: string; target?: string };

    const ACCENT: Record<string, string> = {
        primary: 'var(--tan-light)',
        blue: '#4a9eff',
        green: '#52b788',
        orange: '#ff9f45',
        purple: '#c77dff',
    };

    const ANNOUNCE: [string, string][] = [
        ['/announceblue', 'blue'],
        ['/announcegreen', 'green'],
        ['/announceorange', 'orange'],
        ['/announcepurple', 'purple'],
        ['/announce', 'primary'],
    ];

    function cutVerb(text: string, verb: string): string | null {
        if (text === verb) return '';
        if (text.startsWith(verb + ' ')) return text.slice(verb.length + 1);
        return null;
    }

    function parseLine(text: string): Parsed {
        for (const [verb, color] of ANNOUNCE) {
            const rest = cutVerb(text, verb);
            if (rest !== null) return { mode: 'announce', body: rest, verb, color };
        }
        const so = cutVerb(text, '/shoutout');
        if (so !== null) {
            const trimmed = so.replace(/^ +/, '');
            const sp = trimmed.indexOf(' ');
            const rawTarget = sp === -1 ? trimmed : trimmed.slice(0, sp);
            const remainder = sp === -1 ? '' : trimmed.slice(sp + 1).replace(/^ +/, '');
            return { mode: 'shoutout', body: remainder, verb: '/shoutout', target: rawTarget.replace(/^@/, '') };
        }
        const pin = cutVerb(text, '/pin');
        if (pin !== null) return { mode: 'pin', body: pin, verb: '/pin' };
        const me = cutVerb(text, '/me');
        if (me !== null) return { mode: 'me', body: me, verb: '/me' };
        return { mode: 'chat', body: text };
    }

    function verbLabelOf(p: Parsed): string {
        if (p.mode === 'announce') return p.color === 'primary' ? '/announce' : `/announce (${p.color})`;
        return p.verb ?? '';
    }

    function initBuilder(root: HTMLElement) {
        if (root.dataset.ready) return;
        root.dataset.ready = '1';

        const payload: Payload = JSON.parse(root.querySelector('[data-builder-json]')?.textContent || 'null');
        if (!payload) return;
        const { data, ui } = payload;
        const surfaces = new Map(data.surfaces.map((s) => [s.id, s]));

        const $ = <T extends Element>(sel: string) => root.querySelector<T>(sel)!;
        const ta = $<HTMLTextAreaElement>('[data-template]');
        const nameInput = $<HTMLInputElement>('[data-name]');
        const aliasInput = $<HTMLInputElement>('[data-aliases]');
        const permSel = $<HTMLSelectElement>('[data-perm]');
        const cdInput = $<HTMLInputElement>('[data-cooldown]');
        const styleSel = $<HTMLSelectElement>('[data-style]');
        const surfaceSel = $<HTMLSelectElement>('[data-surface]');
        const sendLink = $<HTMLAnchorElement>('[data-send]');
        const moduleLink = $<HTMLAnchorElement>('[data-module-link]');
        const copyBtn = $<HTMLButtonElement>('[data-copy]');
        const chat = $<HTMLElement>('[data-chat]');
        const chatTag = $<HTMLElement>('[data-chat-tag]');
        const avatarSrc = chat.dataset.avatar ?? '';

        let mode: 'custom' | 'module' = 'custom';
        let surfaceId = 'custom';
        const current = () => surfaces.get(surfaceId)!;

        const cleanName = () =>
            nameInput.value.trim().replace(/^!+/, '').replace(/\s+/g, '').toLowerCase().slice(0, data.limits.nameMax);

        const cleanAliases = () =>
            aliasInput.value
                .split(',')
                .map((a) => a.trim().replace(/^!+/, '').replace(/\s+/g, '').toLowerCase())
                .filter(Boolean)
                .slice(0, data.limits.aliasMax);

        const cleanCooldown = () => {
            const n = Math.floor(Number(cdInput.value) || 0);
            return Math.min(Math.max(n, 0), data.limits.cooldownMax);
        };

        // The meaningful lines, mirroring the bot: trailing whitespace trimmed,
        // blank lines dropped, first line carrying the selected style prefix.
        const lines = () => {
            const raw = ta.value.split(/\r\n|\r|\n/).map((l) => l.replace(/[ \t]+$/, '')).filter((l) => l !== '');
            if (mode === 'custom' && styleSel.value && raw.length > 0) raw[0] = styleSel.value + raw[0];
            return raw;
        };

        // --- Token substitution: known tokens become highlighted samples,
        // unknown {tokens} stay marked, exactly like the dashboard rehearsal.
        type Seg = { text: string; kind: 'plain' | 'sample' | 'unknown' };
        const rint = (lo: number, hi: number) => String(lo + Math.floor(Math.random() * (hi - lo + 1)));

        function resolveToken(body: string): string | null {
            const samples = new Map(current().vars.map((x) => [x.token.slice(1, -1), x.sample]));
            if (samples.has(body)) return samples.get(body)!;
            // Aliases the bot honors but the palette hides for clarity.
            if (body === 'sender' && samples.has('user')) return samples.get('user')!;
            if (body === 'target' && samples.has('touser')) return samples.get('touser')!;
            if (body === 'touser' && samples.has('target')) return samples.get('target')!;
            if (body === 'random') return rint(1, 100);
            const rand = body.match(/^random:(-?\d+)-(-?\d+)$/);
            if (rand) {
                const lo = parseInt(rand[1], 10);
                const hi = parseInt(rand[2], 10);
                return hi >= lo ? rint(lo, hi) : null;
            }
            if (body.startsWith('choice:')) {
                const options = body.slice(7).split(',').map((o) => o.trim()).filter(Boolean);
                return options.length ? options[Math.floor(Math.random() * options.length)] : null;
            }
            if (mode === 'custom' && body.startsWith('counter:') && body.length > 'counter:'.length) return '128';
            return null;
        }

        function segmentsOf(body: string): Seg[] {
            const out: Seg[] = [];
            const re = /\{([a-z_]+(?:\.[a-z_]+)?(?::[^{}]*)?)\}/gi;
            let last = 0;
            for (const m of body.matchAll(re)) {
                if (m.index! > last) out.push({ text: body.slice(last, m.index), kind: 'plain' });
                const value = resolveToken(m[1]);
                if (value !== null) out.push({ text: value, kind: 'sample' });
                else out.push({ text: m[0], kind: 'unknown' });
                last = m.index! + m[0].length;
            }
            if (last < body.length) out.push({ text: body.slice(last), kind: 'plain' });
            return out;
        }

        // --- Rehearsal DOM (ported ChatPreview markup, textContent only) -----
        const el = (tag: string, className: string, text?: string) => {
            const node = document.createElement(tag);
            node.className = className;
            if (text !== undefined) node.textContent = text;
            return node;
        };

        function botName(): HTMLElement {
            const who = el('span', 'who bot-name');
            if (avatarSrc) {
                const img = document.createElement('img');
                img.className = 'bot-avatar';
                img.src = avatarSrc;
                img.alt = '';
                who.append(img);
            }
            who.append('ItsBagelBot');
            return who;
        }

        function msgWithSegments(className: string, segments: Seg[]): HTMLElement {
            const msg = el('span', className);
            for (const seg of segments) {
                if (seg.kind === 'plain') {
                    msg.append(seg.text);
                } else {
                    const mark = el('mark', seg.kind === 'unknown' ? 'unknown' : '', seg.text);
                    if (seg.kind === 'unknown') mark.title = ui.unknownVar;
                    msg.append(mark);
                }
            }
            return msg;
        }

        function viaBadge(label: string, inline = false): HTMLElement {
            return el('span', inline ? 'via inline' : 'via', `Twitch ${label}`);
        }

        function botLine(view: Parsed & { segments: Seg[] }, index: number): HTMLElement {
            const line = el('div', 'line bot');
            line.style.setProperty('--reply-delay', `${index * 140}ms`);
            if (view.mode !== 'chat') line.classList.add('special');
            if (view.mode === 'me') {
                line.classList.remove('special');
                line.classList.add('me');
            }
            line.append(botName());

            if (view.mode === 'announce') {
                const box = el('div', 'announce');
                box.style.setProperty('--acc', ACCENT[view.color ?? 'primary']);
                const head = el('span', 'announce-head');
                head.append(viaBadge(verbLabelOf(view)), ui.announcement);
                box.append(head);
                box.append(view.segments.length
                    ? msgWithSegments('msg reply', view.segments)
                    : el('span', 'msg empty', ui.addMessageAfter.replace('{verb}', view.verb ?? '')));
                line.append(box);
            } else if (view.mode === 'shoutout') {
                const box = el('div', 'shoutout');
                box.append(viaBadge('/shoutout'));
                if (view.target) {
                    const msg = el('span', 'msg reply', `${ui.shoutsOut} `);
                    const strong = el('strong', '', `@${view.target}`);
                    msg.append(strong);
                    box.append(msg);
                } else {
                    box.append(el('span', 'msg empty', ui.nameChannel));
                }
                line.append(box);
            } else if (view.mode === 'pin') {
                const box = el('div', 'pin');
                const head = el('span', 'pin-head');
                head.append(viaBadge('/pin'), ui.pinnedForStream);
                box.append(head);
                box.append(view.segments.length
                    ? msgWithSegments('msg reply', view.segments)
                    : el('span', 'msg empty', ui.addMessageAfter.replace('{verb}', '/pin')));
                line.append(box);
            } else if (view.mode === 'me') {
                line.append(viaBadge('/me', true));
                line.append(view.segments.length
                    ? msgWithSegments('msg reply action', view.segments)
                    : el('span', 'msg empty', ui.addActionAfterMe));
            } else {
                line.append(msgWithSegments('msg reply', view.segments));
            }
            return line;
        }

        // Event-driven surfaces (alerts, shoutout, channel points…) rehearse
        // without a viewer line — the firing event becomes the box tag, exactly
        // like the dashboard's module-reply inspectors.
        const promptKind = () => {
            const surface = current();
            if (mode === 'custom' || surface.prompt.startsWith('!')) return 'command';
            if (surface.id === 'triggers') return 'message';
            return 'event';
        };

        function clearChat() {
            for (const node of [...chat.children]) if (node !== chatTag) node.remove();
        }

        function viewerLine(): HTMLElement | null {
            const kind = promptKind();
            if (kind === 'event') return null;
            const surface = current();
            const line = el('div', 'line viewer');
            const who = el('span', 'who viewer-name', surface.vars.find((x) => x.token === '{user}')?.sample ?? 'maya_live');
            const text = mode === 'custom' ? `!${cleanName() || 'command'}` : surface.prompt;
            const msg = el('span', kind === 'message' ? 'msg plain' : 'msg', text);
            line.append(who, msg);
            return line;
        }

        function renderReplies() {
            clearChat();
            chatTag.textContent = promptKind() === 'event' ? current().prompt : ui.rehearsal;
            const viewer = viewerLine();
            if (viewer) chat.append(viewer);

            const out = lines().slice(0, data.limits.linesMax);
            if (out.length === 0) {
                const line = el('div', 'line bot');
                line.append(botName(), el('span', 'msg empty', ui.nothingToSay));
                chat.append(line);
                return;
            }
            out.forEach((raw, i) => {
                const parsed = parseLine(raw);
                chat.append(botLine({ ...parsed, segments: segmentsOf(parsed.body) }, i));
            });
        }

        function renderTyping() {
            clearChat();
            chatTag.textContent = promptKind() === 'event' ? current().prompt : ui.rehearsal;
            const viewer = viewerLine();
            if (viewer) chat.append(viewer);
            const line = el('div', 'line bot');
            const msg = el('span', 'msg typing');
            msg.setAttribute('aria-label', ui.ariaTyping);
            msg.append(el('span', 'tdot'), el('span', 'tdot'), el('span', 'tdot'));
            line.append(botName(), msg);
            chat.append(line);
        }

        // Typing beat: edits flip to the dots, settle back to the reply — the
        // dashboard's debounce, same 550ms.
        let settle: ReturnType<typeof setTimeout> | undefined;
        let firstRender = true;
        function schedulePreview() {
            if (firstRender) {
                firstRender = false;
                renderReplies();
                return;
            }
            renderTyping();
            clearTimeout(settle);
            settle = setTimeout(renderReplies, 550);
        }

        // --- Variable palette -------------------------------------------------
        function insert(text: string) {
            const a = ta.selectionStart ?? ta.value.length;
            const b = ta.selectionEnd ?? ta.value.length;
            ta.value = ta.value.slice(0, a) + text + ta.value.slice(b);
            ta.focus();
            ta.setSelectionRange(a + text.length, a + text.length);
            update();
        }

        function renderVars() {
            const box = $<HTMLElement>('[data-vars]');
            box.replaceChildren();
            for (const item of current().vars) {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'var';
                const code = el('code', '', item.token);
                const span = el('span', '');
                span.append(el('b', '', item.name), el('small', '', item.desc));
                btn.append(code, span, el('i', '', '+'));
                btn.addEventListener('click', () => insert(item.token));
                box.append(btn);
            }
        }

        // --- Recipes ----------------------------------------------------------
        const recipesBox = $<HTMLElement>('[data-recipes]');
        for (const recipe of ui.recipes) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.textContent = recipe.label;
            btn.addEventListener('click', () => {
                ta.value = recipe.text;
                update();
            });
            recipesBox.append(btn);
        }

        // --- Validation + outputs ---------------------------------------------
        function problem(): string | null {
            const out = lines();
            if (mode === 'custom' && !cleanName()) return ui.statusName;
            if (out.length === 0) return ui.statusEmpty;
            if (out.length > data.limits.linesMax) return ui.statusLines;
            if (out.some((l) => l.length > data.limits.lineMax)) return ui.statusLineLen;
            return null;
        }

        function dashboardURL(): string {
            const url = new URL(data.dashboardOrigin + '/commands');
            url.searchParams.set('compose', '1');
            url.searchParams.set('name', cleanName());
            url.searchParams.set('response', lines().join('\n'));
            url.searchParams.set('perm', permSel.value);
            url.searchParams.set('cooldown', String(cleanCooldown()));
            const aliases = cleanAliases();
            if (aliases.length) url.searchParams.set('aliases', aliases.join(','));
            if (data.lang === 'fr') url.searchParams.set('lang', 'fr');
            return url.toString();
        }

        function update() {
            const surface = current();
            const err = problem();
            const out = lines();

            $('[data-count]').textContent = String(Math.max(0, ...out.map((l) => l.length), 0));
            $('[data-context]').textContent = mode === 'custom' ? `!${cleanName() || 'yourcommand'}` : surface.label;
            $('[data-scope]').textContent = surface.label;
            $('[data-preview-note]').textContent = surface.hint;
            $('[data-valid]').textContent = err ?? ui.statusReady;
            $('[data-valid]').classList.toggle('is-bad', !!err);
            $('[data-action-title]').textContent = mode === 'custom' ? ui.sendTitle : ui.copyTitleModule;

            // Send-to-dashboard: only meaningful for custom commands.
            $('[data-send-wrap]').toggleAttribute('hidden', mode !== 'custom');
            if (mode === 'custom') {
                sendLink.href = err ? '#' : dashboardURL();
                sendLink.classList.toggle('is-disabled', !!err);
                sendLink.setAttribute('aria-disabled', err ? 'true' : 'false');
            }

            // Chat-paste path: secondary for single-line custom commands, the
            // main path for module templates. Multi-line custom commands can't
            // ride one chat message, so it steps aside and the dashboard carries it.
            const output = $<HTMLElement>('[data-output]');
            const copyWrap = $<HTMLElement>('[data-copy-wrap]');
            if (mode === 'custom') {
                $('[data-copy-title]').textContent = ui.copyTitleCustom;
                moduleLink.hidden = true;
                const single = out.length === 1;
                copyWrap.toggleAttribute('hidden', !single);
                if (single) output.textContent = `!cmd add ${cleanName() || 'yourcommand'} ${out[0]}`;
            } else {
                $('[data-copy-title]').textContent = ui.copyBodyModule;
                copyWrap.removeAttribute('hidden');
                output.textContent = ta.value.trim();
                moduleLink.hidden = false;
                moduleLink.href = data.dashboardOrigin + surface.dashPath + (data.lang === 'fr' ? '?lang=fr' : '');
            }
            copyBtn.disabled = !!err;

            schedulePreview();
        }

        function setSurface(id: string) {
            surfaceId = id;
            const surface = current();
            $('[data-hint]').textContent = surface.hint;
            ta.value = surface.example;
            renderVars();
            update();
        }

        function setMode(next: 'custom' | 'module') {
            mode = next;
            root.querySelectorAll<HTMLButtonElement>('[data-mode]').forEach((btn) => {
                const on = btn.dataset.mode === next;
                btn.classList.toggle('active', on);
                btn.setAttribute('aria-pressed', String(on));
            });
            $('[data-module-pick]').toggleAttribute('hidden', next !== 'module');
            $('[data-command-fields]').toggleAttribute('hidden', next !== 'custom');
            $('[data-more]').toggleAttribute('hidden', next !== 'custom');
            recipesBox.toggleAttribute('hidden', next !== 'custom');
            setSurface(next === 'custom' ? 'custom' : surfaceSel.value);
        }

        root.querySelectorAll<HTMLButtonElement>('[data-mode]').forEach((btn) =>
            btn.addEventListener('click', () => setMode(btn.dataset.mode as 'custom' | 'module')),
        );
        surfaceSel.addEventListener('change', () => setSurface(surfaceSel.value));
        [ta, nameInput, aliasInput, permSel, cdInput, styleSel].forEach((input) =>
            input.addEventListener('input', update),
        );

        copyBtn.addEventListener('click', async () => {
            const label = copyBtn.querySelector('span')!;
            try {
                await navigator.clipboard.writeText($('[data-output]').textContent || '');
                label.textContent = ui.copied;
            } catch {
                label.textContent = ui.copyFail;
            }
            setTimeout(() => (label.textContent = ui.copyCta), 1800);
        });

        sendLink.addEventListener('click', (event) => {
            if (sendLink.classList.contains('is-disabled')) event.preventDefault();
        });

        setSurface('custom');
    }

    function setup() {
        document.querySelectorAll<HTMLElement>('[data-builder]').forEach(initBuilder);
    }

    setup();
    document.addEventListener('astro:page-load', setup);
</script>

<style>
