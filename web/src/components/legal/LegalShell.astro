---
/**
 * LegalShell — legal pages that respect the reader. A thin reading-progress
 * bar, a sticky scrollspy table of contents (desktop), and a "plain words"
 * one-liner on every section so nobody has to parse legalese to get the gist.
 * Pages pass sections (id, heading, plain) and provide the body of each
 * section through a matching named slot.
 */
interface Section {
    id: string;
    heading: string;
    plain: string;
}

interface Props {
    updated: string;
    sections: Section[];
}

const { updated, sections } = Astro.props;
---

<div class="lshell" data-legal>
    <div class="lshell__progress" aria-hidden="true">
        <span class="lshell__progress-fill" data-legal-progress></span>
    </div>

    <div class="lshell__grid">
        <nav class="lshell__toc" aria-label="On this page">
            <span class="lshell__toc-label">On this page</span>
            <ul>
                {sections.map((section) => (
                    <li>
                        <a href={`#${section.id}`} data-legal-link={section.id}>{section.heading}</a>
                    </li>
                ))}
            </ul>
        </nav>

        <article class="lshell__content">
            <p class="lshell__updated" data-reveal>Last updated: {updated}</p>

            {await Promise.all(sections.map(async (section, i) => (
                <div class="lshell__block" id={section.id} data-legal-section data-reveal style={`--reveal-i: ${Math.min(i + 1, 6)}`}>
                    <h2>{section.heading}</h2>
                    <p class="lshell__plain">
                        <span class="lshell__plain-tag">plain words</span>
                        {section.plain}
                    </p>
                    <Fragment set:html={await Astro.slots.render(section.id)} />
                </div>
            )))}
        </article>
    </div>
</div>

<style>
    .lshell {
        max-width: var(--content-max, 1200px);
        margin: 0 auto;
        padding: 0 24px 96px;
    }

    /* ── Reading progress ── */

    .lshell__progress {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        z-index: 90;
        background: transparent;
        pointer-events: none;
    }

    .lshell__progress-fill {
        display: block;
        height: 100%;
        width: 100%;
        background: linear-gradient(90deg, var(--green-glow, #52b788), var(--tan, #c9a87c));
        transform: scaleX(var(--read, 0));
        transform-origin: left;
        box-shadow: 0 0 12px rgba(201, 168, 124, 0.5);
    }

    /* ── Layout ── */

    .lshell__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 48px;
    }

    @media (min-width: 980px) {
        .lshell__grid {
            grid-template-columns: 220px minmax(0, 1fr);
            gap: 72px;
        }
    }

    /* ── TOC ── */

    .lshell__toc { display: none; }

    @media (min-width: 980px) {
        .lshell__toc {
            display: block;
            position: sticky;
            top: calc(var(--nav-offset, 76px) + 32px);
            align-self: start;
        }
    }

    .lshell__toc-label {
        display: block;
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.64rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted, #888077);
        margin-bottom: 16px;
    }

    .lshell__toc ul {
        display: flex;
        flex-direction: column;
        gap: 2px;
        border-left: 1px solid var(--border, rgba(201, 168, 124, 0.15));
    }

    .lshell__toc a {
        position: relative;
        display: block;
        padding: 7px 0 7px 16px;
        font-family: var(--font-body, "DM Sans", sans-serif);
        font-size: 0.82rem;
        color: var(--muted, #888077);
        transition: color 200ms ease, padding-left 300ms var(--ease-out-expo);
    }

    .lshell__toc a::before {
        content: "";
        position: absolute;
        left: -1px;
        top: 20%;
        bottom: 20%;
        width: 1px;
        background: var(--tan, #c9a87c);
        transform: scaleY(0);
        transition: transform 300ms var(--ease-out-expo);
    }

    @media (hover: hover) and (pointer: fine) {
        .lshell__toc a:hover { color: var(--tan-light, #e0c49a); }
    }

    .lshell__toc a.is-current {
        color: var(--tan-light, #e0c49a);
        padding-left: 20px;
    }

    .lshell__toc a.is-current::before { transform: scaleY(1); }

    /* ── Content ── */

    .lshell__content { max-width: var(--content-text, 68ch); }

    .lshell__updated {
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.78rem;
        color: var(--green-glow, #52b788);
        letter-spacing: 0.08em;
        margin-bottom: 48px;
    }

    .lshell__block { scroll-margin-top: calc(var(--nav-offset, 76px) + 24px); }

    .lshell__block h2 {
        font-family: var(--font-display, "Syne", sans-serif);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--white, #f0ece4);
        letter-spacing: -0.01em;
        margin: 52px 0 12px;
    }

    .lshell__block:first-of-type h2 { margin-top: 0; }

    .lshell__plain {
        font-family: var(--font-body, "DM Sans", sans-serif);
        font-size: 0.85rem;
        line-height: 1.6;
        color: rgba(240, 236, 228, 0.75);
        background: rgba(82, 183, 136, 0.05);
        border: 1px solid rgba(82, 183, 136, 0.16);
        border-radius: 10px;
        padding: 10px 14px;
        margin: 0 0 16px;
    }

    .lshell__plain-tag {
        display: inline-block;
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.6rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--green-glow, #52b788);
        margin-right: 8px;
    }

    .lshell__block :global(p),
    .lshell__block :global(ul) {
        font-family: var(--font-body, "DM Sans", sans-serif);
        font-size: 0.94rem;
        color: var(--muted, #888077);
        line-height: 1.8;
        margin-bottom: 14px;
    }

    .lshell__block :global(ul) {
        padding-left: 1.4em;
        list-style-type: disc;
    }

    .lshell__block :global(ul li) { margin-bottom: 7px; }
    .lshell__block :global(ul li::marker) { color: var(--green-glow, #52b788); }

    .lshell__block :global(a) {
        color: var(--tan, #c9a87c);
        border-bottom: 1px solid transparent;
        transition: color 180ms ease, border-color 180ms ease;
    }

    .lshell__block :global(a:hover) {
        color: var(--tan-light, #e0c49a);
        border-bottom-color: var(--tan-light, #e0c49a);
    }

    @media (prefers-reduced-motion: reduce) {
        .lshell__toc a, .lshell__toc a::before { transition: none; }
    }

    @media (max-width: 480px) {
        .lshell { padding: 0 16px 72px; }
        .lshell__block h2 { font-size: 1.1rem; margin-top: 40px; }
    }
</style>

<script>
    /* Reading progress + TOC scrollspy. One shared scroll listener per page. */
    function setupLegal(root: HTMLElement) {
        if (root.dataset.legalReady === 'true') return;
        root.dataset.legalReady = 'true';

        const fill = root.querySelector<HTMLElement>('[data-legal-progress]');
        const article = root.querySelector<HTMLElement>('.lshell__content');
        const sections = Array.from(root.querySelectorAll<HTMLElement>('[data-legal-section]'));
        const links = new Map(
            Array.from(root.querySelectorAll<HTMLAnchorElement>('[data-legal-link]'))
                .map((a) => [a.dataset.legalLink as string, a]),
        );

        let ticking = false;

        function update() {
            ticking = false;
            if (article && fill) {
                const rect = article.getBoundingClientRect();
                const total = rect.height - window.innerHeight;
                const read = total > 0 ? Math.min(1, Math.max(0, -rect.top / total)) : 1;
                fill.style.setProperty('--read', read.toFixed(4));
            }

            /* Current section: the last one whose top passed the upper third */
            let currentId = sections[0]?.id;
            for (const section of sections) {
                if (section.getBoundingClientRect().top < window.innerHeight * 0.35) {
                    currentId = section.id;
                }
            }
            links.forEach((link, id) => link.classList.toggle('is-current', id === currentId));
        }

        function onScroll() {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(update);
        }

        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        update();
    }

    function setup() {
        document.querySelectorAll<HTMLElement>('[data-legal]').forEach(setupLegal);
    }

    setup();
    document.addEventListener('astro:page-load', setup);
</script>
