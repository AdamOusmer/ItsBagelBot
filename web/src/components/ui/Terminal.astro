---
export interface Props {
    title?: string;
    channel?: string;
    lines?: string[];
}

const {
    title = "ItsBagelBot — setup",
    channel = "your_channel",
    lines = [
        "Connecting to Twitch IRC",
        "Loading chat commands",
        "Initializing chatter interactions",
        "Setting up moderation tools",
        "Configuring polls & giveaways",
        "Starting song requests",
        `BagelBot live on ${channel}`,
    ],
} = Astro.props;
---

<div class="terminal" role="log" aria-live="polite">
    <div class="terminal__bar">
        <div class="terminal__dots">
            <span class="terminal__dot terminal__dot--red"></span>
            <span class="terminal__dot terminal__dot--yellow"></span>
            <span class="terminal__dot terminal__dot--green"></span>
        </div>
        <span class="terminal__title">{title}</span>
    </div>
    <div class="terminal__body">
        <div class="terminal__prompt">
            <span class="terminal__prompt-symbol">$</span>
            <span class="terminal__prompt-cmd">bagelbot start --channel <span class="terminal__channel">{channel}</span></span>
        </div>
        <ul class="terminal__lines" id="terminalLines">
            {lines.map((line) => (
                <li class="terminal__line" aria-label={line}>
                    <span class="terminal__spinner" aria-hidden="true"></span>
                    <span class="terminal__dot-done" aria-hidden="true"></span>
                    <span class="terminal__line-text">{line}</span>
                </li>
            ))}
        </ul>
        <div class="terminal__cursor-line" id="terminalCursorLine" aria-hidden="true">
            <span class="terminal__caret"></span>
        </div>
    </div>
</div>

<style>
    .terminal {
        background: var(--card-bg, #111110);
        border: 1px solid var(--border, rgba(201, 168, 124, 0.15));
        border-radius: 12px;
        overflow: hidden;
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.8125rem;
        box-shadow:
            0 0 0 1px rgba(0,0,0,0.4),
            0 24px 64px rgba(0,0,0,0.5),
            0 0 40px rgba(82, 183, 136, 0.04);
        max-width: 560px;
        width: 100%;
    }

    /* ── Title bar ── */
    .terminal__bar {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: rgba(255,255,255,0.03);
        border-bottom: 1px solid var(--border, rgba(201, 168, 124, 0.15));
    }

    .terminal__dots {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .terminal__dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
    }
    .terminal__dot--red    { background: #ff5f57; }
    .terminal__dot--yellow { background: #febc2e; }
    .terminal__dot--green  { background: #28c840; }

    .terminal__title {
        flex: 1;
        text-align: center;
        color: var(--muted, #888077);
        font-size: 0.75rem;
        letter-spacing: 0.02em;
        user-select: none;
    }

    /* ── Body ── */
    .terminal__body {
        padding: 20px 20px 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .terminal__prompt {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--tan-light, #e0c49a);
        white-space: nowrap;
        overflow: hidden;
    }

    .terminal__prompt-symbol {
        color: var(--green-glow, #52b788);
        font-weight: 600;
        flex-shrink: 0;
    }

    .terminal__prompt-cmd {
        color: var(--muted, #888077);
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .terminal__channel {
        color: var(--tan-light, #e0c49a);
    }

    /* ── Lines list ── */
    .terminal__lines {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .terminal__line {
        display: flex;
        align-items: center;
        gap: 9px;
        opacity: 0;
        transform: translateY(4px);
        transition: none;
        color: var(--muted, #888077);
        line-height: 1.5;
    }

    /* States: idle → loading → done */
    .terminal__line.is-loading {
        opacity: 1;
        transform: translateY(0);
        transition: opacity 200ms ease, transform 200ms var(--ease-out-expo, cubic-bezier(0.16,1,0.3,1));
    }

    .terminal__line.is-done {
        color: var(--green-glow, #52b788);
    }

    /* Spinner (visible while loading) */
    .terminal__spinner {
        display: none;
        width: 10px;
        height: 10px;
        border: 1.5px solid rgba(82, 183, 136, 0.25);
        border-top-color: var(--green-glow, #52b788);
        border-radius: 50%;
        flex-shrink: 0;
        animation: spin 0.65s linear infinite;
    }

    .terminal__line.is-loading .terminal__spinner {
        display: block;
    }

    .terminal__line.is-done .terminal__spinner {
        display: none;
    }

    /* Green dot (visible when done) */
    .terminal__dot-done {
        display: none;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--green-glow, #52b788);
        box-shadow: 0 0 6px rgba(82, 183, 136, 0.6);
        flex-shrink: 0;
    }

    .terminal__line.is-done .terminal__dot-done {
        display: block;
        animation: popIn 250ms var(--ease-out-back, cubic-bezier(0.34,1.56,0.64,1)) both;
    }

    /* Blinking caret after all lines */
    .terminal__cursor-line {
        display: flex;
        align-items: center;
        height: 18px;
        opacity: 0;
        transition: opacity 200ms ease;
    }

    .terminal__cursor-line.is-visible {
        opacity: 1;
    }

    .terminal__caret {
        display: inline-block;
        width: 7px;
        height: 15px;
        background: var(--green-glow, #52b788);
        border-radius: 1px;
        animation: blink 1.1s step-end infinite;
        box-shadow: 0 0 6px rgba(82, 183, 136, 0.5);
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    @keyframes popIn {
        from { transform: scale(0); opacity: 0; }
        to   { transform: scale(1); opacity: 1; }
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0; }
    }
</style>

<script>
    const LOAD_MS  = 900;  // how long each line spins before turning green
    const GAP_MS   = 120;  // pause between one line finishing and the next starting
    const START_MS = 400;  // delay before the first line appears

    function wait(ms: number) {
        return new Promise<void>((r) => setTimeout(r, ms));
    }

    async function run(terminal: HTMLElement) {
        const lines = terminal.querySelectorAll<HTMLElement>(".terminal__line");
        const cursorLine = terminal.querySelector<HTMLElement>(".terminal__cursor-line");

        await wait(START_MS);

        for (const line of Array.from(lines)) {
            line.classList.add("is-loading");
            await wait(LOAD_MS);
            line.classList.add("is-done");
            await wait(GAP_MS);
        }

        cursorLine?.classList.add("is-visible");
    }

    document.querySelectorAll<HTMLElement>(".terminal").forEach((terminal) => {
        const observer = new IntersectionObserver(
            (entries) => {
                if (entries[0].isIntersecting) {
                    observer.disconnect();
                    run(terminal);
                }
            },
            { threshold: 0.25 }
        );
        observer.observe(terminal);
    });
</script>
