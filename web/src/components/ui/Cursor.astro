<!-- Persisted across navigations: the script grabs these once and drives them
     with a rAF loop, so they must survive the view-transition swap or the
     cursor would freeze at its default corner until the next mousemove. -->
<div class="cursor" id="cursor" transition:persist></div>
<div class="cursor-ring" id="cursorRing" transition:persist></div>

<style>
    /* ── dot ── */
    .cursor {
        position: fixed;
        width: 12px;
        height: 12px;
        left: -6px;
        top: -6px;
        border-radius: 50%;
        background: var(--tan, #c9a87c);
        pointer-events: none;
        z-index: 9999;
        will-change: transform, opacity;
        mix-blend-mode: difference;
        transition: opacity 200ms;
    }

    /* ── ring ── */
    .cursor-ring {
        position: fixed;
        left: 0;
        top: 0;
        width: 36px;
        height: 36px;
        border: 2px solid var(--tan, #c9a87c);
        border-radius: 18px;
        pointer-events: none;
        z-index: 9998;
        opacity: 0.5;
        transition: opacity 250ms, background 250ms, border-color 250ms;
        will-change: transform, width, height, border-radius;
    }

    /* morphed state: ring fills with a tan wash, stamps itself onto the element */
    :global(.cursor-ring.morph) {
        opacity: 1;
        background: rgba(201, 168, 124, 0.22);
        border-color: var(--tan, #c9a87c);
    }

    /* hides native cursor on fine-pointer desktops (set by JS, not by CSS alone,
       to avoid hiding it before the script has run) */
    :global(html.bb-cursor-on),
    :global(html.bb-cursor-on *) {
        cursor: none !important;
    }

    @media (max-width: 900px), (pointer: coarse) {
        .cursor,
        .cursor-ring {
            display: none;
        }
    }
</style>

<script>
    const dot  = document.getElementById('cursor')! as HTMLDivElement;
    const ring = document.getElementById('cursorRing')! as HTMLDivElement;

    // Only activate on desktop fine-pointer (same breakpoint as the dashboard).
    const fine = window.matchMedia('(min-width: 901px) and (pointer: fine)');
    if (!fine.matches) {
        // Remove both elements so they don't take up any painting budget.
        dot.remove();
        ring.remove();
    } else {
        // ── state ──────────────────────────────────────────────────────────────
        let mx = innerWidth / 2,
            my = innerHeight / 2;

        // ring geometry (all in px): top-left x/y, width, height, radius
        let x = mx, y = my, w = 36, h = 36, r = 18;

        let target: HTMLElement | null = null;
        let raf = 0;
        let lastMove = 0;

        // ── helpers ────────────────────────────────────────────────────────────
        const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
        const can  = () => fine.matches && !document.hidden;
        const start = () => { if (!raf && can()) raf = requestAnimationFrame(tick); };

        // ── animation loop ─────────────────────────────────────────────────────
        function tick(now: number) {
            const hovering = !!target && target.isConnected;

            // Dot: tracks 1:1, fades while morphed onto a target.
            dot.style.transform = `translate(${mx}px, ${my}px)`;
            dot.style.opacity   = hovering ? '0' : '1';

            // Compute destination for the ring.
            let tx: number, ty: number, tw: number, th: number, tr: number;
            if (hovering) {
                const b   = target!.getBoundingClientRect();
                const pad = 6;
                tw = b.width  + pad * 2;
                th = b.height + pad * 2;
                tx = b.left   - pad;
                ty = b.top    - pad;
                // Inherit the element's border-radius + padding, clamped to a pill.
                const elRadius = parseFloat(getComputedStyle(target!).borderRadius) || 8;
                tr = Math.min(elRadius + pad, th / 2);
            } else {
                tw = 36; th = 36;
                tx = mx - 18; ty = my - 18;
                tr = 18;
            }

            // Lerp ring geometry — faster ease when morphing, slower when releasing.
            const e = hovering ? 0.25 : 0.16;
            x = lerp(x, tx, e);
            y = lerp(y, ty, e);
            w = lerp(w, tw, e);
            h = lerp(h, th, e);
            r = lerp(r, tr, e);

            ring.style.transform    = `translate(${x.toFixed(1)}px, ${y.toFixed(1)}px)`;
            ring.style.width        = `${w.toFixed(1)}px`;
            ring.style.height       = `${h.toFixed(1)}px`;
            ring.style.borderRadius = `${r.toFixed(1)}px`;
            ring.classList.toggle('morph', hovering);

            // Stop the loop once the ring has settled in the idle (dot) position.
            const settled =
                !hovering &&
                Math.abs(x - tx) < 0.3 &&
                Math.abs(y - ty) < 0.3;

            if (!can() || (settled && now - lastMove > 500)) {
                raf = 0;
                return;
            }
            raf = requestAnimationFrame(tick);
        }

        // ── pointer events ─────────────────────────────────────────────────────
        // Selector mirrors the dashboard: anchors, buttons, and opt-in elements.
        const SEL = 'a, button, [data-cursor]';

        const onMove = (e: PointerEvent) => {
            if (e.pointerType === 'touch') return;
            mx = e.clientX;
            my = e.clientY;
            lastMove = performance.now();
            start();
        };

        // Event delegation — catches dynamically added elements too.
        const onOver = (e: PointerEvent) => {
            const el = (e.target as Element | null)?.closest<HTMLElement>(SEL);
            if (el) { target = el; start(); }
        };

        const onOut = (e: PointerEvent) => {
            const el = (e.target as Element | null)?.closest<HTMLElement>(SEL);
            if (el && el === target) { target = null; start(); }
        };

        // Mark html so CSS can hide the native cursor (same class the dashboard uses).
        document.documentElement.classList.add('bb-cursor-on');

        window.addEventListener('pointermove',    onMove, { passive: true });
        document.addEventListener('pointerover',  onOver, { passive: true });
        document.addEventListener('pointerout',   onOut,  { passive: true });
        document.addEventListener('visibilitychange', () => document.hidden || start());

        // Support Astro View Transitions. The dot/ring are transition:persist,
        // so their references stay valid and no listeners need re-binding; just
        // re-assert the cursor-hiding class (a swap can reset <html>) and make
        // sure the loop is running.
        document.addEventListener('astro:page-load', () => {
            document.documentElement.classList.add('bb-cursor-on');
            start();
        });
    }
</script>
