---
import SectionHeading from '../ui/SectionHeading.astro';

interface FaqItem {
    question: string;
    answer: string;
}

const faqs: FaqItem[] = [
    {
        question: 'Is the free plan really free?',
        answer: 'Yes. Every feature is available on the free plan with no limitations. We believe every streamer deserves great tools regardless of budget.',
    },
    {
        question: 'What does priority queue mean?',
        answer: 'Premium subscribers get their bot messages processed before free-tier users during high-traffic periods. This means faster command responses and moderation actions when it matters most.',
    },
    {
        question: 'Can I cancel Premium anytime?',
        answer: "Absolutely. Cancel anytime from your dashboard with no penalties. You'll keep Premium benefits until the end of your billing period.",
    },
    {
        question: "What's included in Enterprise?",
        answer: 'Enterprise plans include dedicated server hardware, multi-streamer management, custom SLAs, and direct engineering support. Contact enterprise@itsbagelbot.com for a tailored quote.',
    },
    {
        question: 'Is ItsBagelBot open source?',
        answer: 'ItsBagelBot is source available, not open source. You can view and audit the code on GitHub, but the license restricts redistribution and commercial use. Transparency without compromise.',
    },
];
---

<section class="pricing-faq">
    <SectionHeading eyebrow="FAQ" title="Common questions." />

    <div class="pricing-faq__list">
        {faqs.map((faq, i) => (
            <details
                class="pricing-faq__item"
                data-reveal
                style={`--reveal-i: ${i}`}
            >
                <summary class="pricing-faq__question">
                    <span>{faq.question}</span>
                    <span class="pricing-faq__icon" aria-hidden="true" />
                </summary>
                <!-- grid-template-rows trick: animates height without JS -->
                <div class="pricing-faq__body">
                    <div class="pricing-faq__answer">
                        <p>{faq.answer}</p>
                    </div>
                </div>
            </details>
        ))}
    </div>
</section>

<style>
    .pricing-faq {
        padding: var(--space-section, 96px) 48px;
        max-width: var(--content-max, 1200px);
        margin: 0 auto;
    }

    .pricing-faq__list {
        max-width: var(--content-narrow, 720px);
        margin: 0 auto;
    }

    /* ── Details / Summary ── */
    .pricing-faq__item {
        border-bottom: 1px solid var(--border, rgba(201, 168, 124, 0.15));
    }

    .pricing-faq__question {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        cursor: pointer;
        padding: 22px 0;
        font-family: var(--font-display, 'Syne', sans-serif);
        font-size: 1rem;
        font-weight: 600;
        color: var(--white, #f0ece4);
        list-style: none;
        user-select: none;
        transition: color 200ms ease;
    }

    /* Remove default marker */
    .pricing-faq__question::-webkit-details-marker { display: none; }
    .pricing-faq__question::marker { display: none; content: ''; }

    @media (hover: hover) and (pointer: fine) {
        .pricing-faq__question:hover {
            color: var(--tan-light, #e0c49a);
        }

        .pricing-faq__question:hover .pricing-faq__icon::before,
        .pricing-faq__question:hover .pricing-faq__icon::after {
            background: var(--tan-light, #e0c49a);
        }
    }

    /* ── +/- icon ── */
    .pricing-faq__icon {
        position: relative;
        width: 20px;
        height: 20px;
        flex-shrink: 0;
    }

    .pricing-faq__icon::before,
    .pricing-faq__icon::after {
        content: '';
        position: absolute;
        background: var(--muted, #888077);
        border-radius: 1px;
        transition:
            transform 340ms var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)),
            background 200ms ease;
    }

    /* Horizontal bar */
    .pricing-faq__icon::before {
        top: 50%;
        left: 50%;
        width: 14px;
        height: 1.5px;
        transform: translate(-50%, -50%);
    }

    /* Vertical bar — rotates to 0deg (becomes horizontal) when open */
    .pricing-faq__icon::after {
        top: 50%;
        left: 50%;
        width: 1.5px;
        height: 14px;
        transform: translate(-50%, -50%);
    }

    .pricing-faq__item[open] .pricing-faq__icon::after {
        transform: translate(-50%, -50%) rotate(90deg);
    }

    .pricing-faq__item[open] .pricing-faq__question {
        color: var(--tan-light, #e0c49a);
    }

    .pricing-faq__item[open] .pricing-faq__icon::before,
    .pricing-faq__item[open] .pricing-faq__icon::after {
        background: var(--tan, #c9a87c);
    }

    /* ── Smooth height expand via grid-template-rows ── */
    .pricing-faq__body {
        display: grid;
        grid-template-rows: 0fr;
        transition:
            grid-template-rows 380ms var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1));
    }

    .pricing-faq__item[open] .pricing-faq__body {
        grid-template-rows: 1fr;
    }

    /* Required inner wrapper to allow the grid row to collapse to 0 */
    .pricing-faq__answer {
        overflow: hidden;
        opacity: 0;
        transition: opacity 280ms ease 60ms;
    }

    .pricing-faq__item[open] .pricing-faq__answer {
        opacity: 1;
    }

    .pricing-faq__answer p {
        font-family: var(--font-body, 'DM Sans', sans-serif);
        font-size: 0.9rem;
        line-height: 1.75;
        color: var(--muted, #888077);
        margin: 0;
        padding-bottom: 24px;
    }

    @media (prefers-reduced-motion: reduce) {
        .pricing-faq__body {
            transition: none;
        }
        .pricing-faq__answer {
            transition: none;
            opacity: 1;
        }
        .pricing-faq__icon::before,
        .pricing-faq__icon::after {
            transition: none;
        }
    }

    /* ── Mobile ── */
    @media (max-width: 640px) {
        .pricing-faq {
            padding: var(--space-section-sm, 80px) 24px;
        }

        .pricing-faq__question {
            font-size: 0.92rem;
            padding: 18px 0;
        }

        .pricing-faq__answer p {
            font-size: 0.85rem;
        }
    }
</style>
