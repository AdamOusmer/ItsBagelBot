---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import CommandBuilder from '../../components/builder/CommandBuilder.astro';
import { builderUI } from '../../i18n/builder';
import { getLangFromUrl, locales, defaultLang } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((l) => ({ params: { lang: l === defaultLang ? undefined : l } }));
}

const lang = getLangFromUrl(Astro.url);
const ui = builderUI(lang);
---

<Layout title={ui.metaTitle} description={ui.metaDesc}>
    <PageHero eyebrow={ui.eyebrow} title={ui.title1} description={`${ui.title2} ${ui.lede}`} />
    <CommandBuilder lang={lang} />
</Layout>
