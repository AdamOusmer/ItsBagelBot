---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/ui/PageHero.astro';
import LegalShell from '../components/legal/LegalShell.astro';

const sections = [
    { id: 'agreement', heading: 'Agreement', plain: 'Using the bot means you accept these rules.' },
    { id: 'service', heading: 'The Service', plain: 'A Twitch bot: moderation, commands, engagement. Provided as-is.' },
    { id: 'account', heading: 'Your Account', plain: 'Your channel, your connection, your responsibility.' },
    { id: 'acceptable-use', heading: 'Acceptable Use', plain: "Don't be a jerk, don't break Twitch's rules, don't abuse the service." },
    { id: 'license', heading: 'Source Available License', plain: 'You can read the code. You cannot resell it.' },
    { id: 'payments', heading: 'Payments, Refunds & Chargebacks', plain: 'Purchases are handled by Tebex. All sales are final. Chargebacks result in an immediate ban.' },
    { id: 'liability', heading: 'Limitation of Liability', plain: "If something breaks, we fix it, but we can't owe you damages." },
    { id: 'termination', heading: 'Termination', plain: 'Break the rules and we may close your account. You can leave whenever.' },
    { id: 'governing-law', heading: 'Governing Law', plain: 'These terms are governed by the laws of Quebec, Canada.' },
    { id: 'changes', heading: 'Changes', plain: 'Terms can change; staying means you accept the new ones.' },
    { id: 'contact', heading: 'Contact', plain: 'Questions go to support@itsbagelbot.com.' },
];
---

<Layout title="Terms of Service — ItsBagelBot" description="ItsBagelBot terms of service. Understand your rights and responsibilities when using our platform.">
    <PageHero eyebrow="Legal" title="Terms of Service" description="The full text, with a plain-words note on every section." />

    <LegalShell updated="July 2026" sections={sections}>
        <Fragment slot="agreement">
            <p>By using ItsBagelBot, you agree to these terms. If you don't agree, please don't use the service. You must be at least 13 years old (or 16 in the EU/EEA) to use this service.</p>
        </Fragment>

        <Fragment slot="service">
            <p>
                ItsBagelBot provides automated chat moderation, commands, and engagement tools for Twitch
                streamers. The service is provided as-is.
            </p>
        </Fragment>

        <Fragment slot="account">
            <p>
                You're responsible for your Twitch account connection and any actions taken by the bot on your
                channel. Keep your credentials secure.
            </p>
        </Fragment>

        <Fragment slot="acceptable-use">
            <p>Don't use ItsBagelBot to:</p>
            <ul>
                <li>Violate Twitch's Terms of Service</li>
                <li>Harass or harm others</li>
                <li>Spam or abuse the service</li>
                <li>Attempt to reverse-engineer or redistribute the software</li>
            </ul>
        </Fragment>

        <Fragment slot="license">
            <p>
                ItsBagelBot's source code is viewable on GitHub under a source-available license. This means you
                can view and audit the code, but you may not redistribute, modify for commercial use, or create
                competing services from it.
            </p>
        </Fragment>

        <Fragment slot="payments">
            <p>
                ItsBagelBot uses Tebex as its official payment and monetization platform. When you purchase a Premium subscription or any other product, Tebex acts as the merchant of record. By completing a purchase, you are also agreeing to <a href="https://checkout.tebex.io/terms" target="_blank" rel="noopener noreferrer">Tebex's Terms and Conditions</a>.
            </p>
            <p>
                <strong>Refund Policy & Chargebacks:</strong> All payments are final and non-refundable unless explicitly required by applicable law. If you experience an issue with a transaction, you must contact our support team first. Opening a payment dispute or chargeback without contacting us will result in the immediate and permanent termination of your ItsBagelBot account.
            </p>
            <p>
                Free tier has no cost and no limitations. Premium ($7 CAD +tx/month) can be canceled anytime prior to the next billing cycle. Enterprise
                pricing is custom and outlined in separate agreements.
            </p>
        </Fragment>

        <Fragment slot="liability">
            <p>
                ItsBagelBot is provided as-is without warranties. We're not liable for any chat moderation
                decisions, missed messages, or service interruptions.
            </p>
        </Fragment>

        <Fragment slot="termination">
            <p>
                We may suspend or terminate accounts that violate these terms. You may delete your account at
                any time.
            </p>
        </Fragment>

        <Fragment slot="governing-law">
            <p>
                These terms shall be governed and construed in accordance with the laws of Quebec, Canada, without regard to its conflict of law provisions.
            </p>
        </Fragment>

        <Fragment slot="changes">
            <p>We may update these terms. Continued use after changes constitutes acceptance.</p>
        </Fragment>

        <Fragment slot="contact">
            <p>
                Questions? Email
                <a href="mailto:support@itsbagelbot.com">support@itsbagelbot.com</a>.
            </p>
        </Fragment>
    </LegalShell>
</Layout>
