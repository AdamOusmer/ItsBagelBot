---
// French pricing route. All copy comes from the shared components, which read
// the locale from the /fr/ URL prefix — so this file mirrors pages/pricing.astro.
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import Tiers from '../../components/pricing/Tiers.astro';
import Faq from '../../components/pricing/Faq.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('pricing.metaTitle')} description={t('pricing.metaDesc')}>
    <PageHero
        eyebrow={t('pricing.eyebrow')}
        title={t('pricing.title')}
        description={t('pricing.desc')}
    />
    <Tiers />
    <Faq />
</Layout>
