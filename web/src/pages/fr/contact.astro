---
// French contact route — mirrors pages/contact.astro; components self-translate
// from the /fr/ URL prefix.
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import Switchboard from '../../components/contact/Switchboard.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('contact.metaTitle')} description={t('contact.metaDesc')}>
    <PageHero
        eyebrow={t('contact.eyebrow')}
        title={t('contact.title')}
        description={t('contact.desc')}
    />
    <Switchboard />
</Layout>
