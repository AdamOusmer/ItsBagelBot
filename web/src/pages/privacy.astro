---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/ui/PageHero.astro';
---

<Layout title="Privacy Policy — ItsBagelBot" description="ItsBagelBot privacy policy. Learn how we handle your data with transparency and respect.">
    <PageHero eyebrow="Legal" title="Privacy Policy" />

    <section class="legal">
        <article class="legal__content">
            <p class="legal__updated" data-reveal style="--reveal-i: 0">Last updated: June 2026</p>

            <div class="legal__block" data-reveal style="--reveal-i: 1">
                <h2>Overview</h2>
                <p>
                    ItsBagelBot is committed to protecting your privacy. This policy explains what data we collect,
                    how we use it, and your rights.
                </p>
            </div>

            <div class="legal__block" data-reveal style="--reveal-i: 2">
                <h2>Data We Collect</h2>
                <p>We collect only what's necessary to provide the service:</p>
                <ul>
                    <li>Twitch account information (username, channel ID) provided during OAuth connection</li>
                    <li>Chat messages processed in real-time for moderation (not stored permanently)</li>
                    <li>Usage analytics (aggregated, anonymized, no PII)</li>
                </ul>
            </div>

            <div class="legal__block" data-reveal style="--reveal-i: 3">
                <h2>Data We Don't Collect</h2>
                <p>We never collect:</p>
                <ul>
                    <li>Personal browsing data</li>
                    <li>IP addresses for tracking</li>
                    <li>Information from third-party trackers</li>
                    <li>Data for advertising purposes</li>
                </ul>
            </div>

            <div class="legal__block" data-reveal style="--reveal-i: 4">
                <h2>How We Use Your Data</h2>
                <p>
                    Solely to provide the ItsBagelBot service: moderate chat, execute commands, and run engagement
                    features. We do not sell, rent, or share your data with third parties.
                </p>
            </div>

            <div class="legal__block" data-reveal style="--reveal-i: 5">
                <h2>Data Storage</h2>
                <p>
                    Chat messages are processed in real-time and not permanently stored. Configuration data is
                    encrypted at rest. All data transit uses TLS 1.3 encryption.
                </p>
            </div>

            <div class="legal__block" data-reveal style="--reveal-i: 6">
                <h2>Your Rights</h2>
                <p>
                    You can request data export or deletion at any time by contacting
                    <a href="mailto:support@itsbagelbot.com">support@itsbagelbot.com</a>. Deleting your account
                    removes all associated data.
                </p>
            </div>

            <div class="legal__block" data-reveal style="--reveal-i: 7">
                <h2>Changes</h2>
                <p>
                    We may update this policy. Significant changes will be communicated via Discord and dashboard
                    notifications.
                </p>
            </div>

            <div class="legal__block" data-reveal style="--reveal-i: 8">
                <h2>Contact</h2>
                <p>
                    Questions about privacy? Email
                    <a href="mailto:support@itsbagelbot.com">support@itsbagelbot.com</a>.
                </p>
            </div>
        </article>
    </section>
</Layout>

<style>
    .legal {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 20px 96px;
    }

    .legal__content {
        max-width: var(--content-text, 68ch);
    }

    .legal__updated {
        font-family: var(--font-mono, "DM Mono", monospace);
        font-size: 0.78rem;
        color: var(--green-glow, #52b788);
        letter-spacing: 0.08em;
        margin-bottom: 48px;
    }

    .legal__block {
        margin-bottom: 0;
    }

    .legal__block h2 {
        font-family: var(--font-display, "Syne", sans-serif);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--white, #f0ece4);
        margin-top: 52px;
        margin-bottom: 14px;
        letter-spacing: -0.01em;
    }

    .legal__block:first-of-type h2 {
        margin-top: 0;
    }

    .legal__block p,
    .legal__block ul {
        font-family: var(--font-body, "DM Sans", sans-serif);
        font-size: 0.94rem;
        color: var(--muted, #888077);
        line-height: 1.8;
        margin-bottom: 14px;
    }

    .legal__block ul {
        padding-left: 1.4em;
        list-style-type: disc;
    }

    .legal__block ul li {
        margin-bottom: 7px;
    }

    .legal__block ul li::marker {
        color: var(--green-glow, #52b788);
    }

    .legal__block a {
        color: var(--tan, #c9a87c);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: color 180ms ease, border-color 180ms ease;
    }

    .legal__block a:hover {
        color: var(--tan-light, #e0c49a);
        border-bottom-color: var(--tan-light, #e0c49a);
    }

    @media (max-width: 480px) {
        .legal {
            padding: 0 16px 72px;
        }

        .legal__block h2 {
            font-size: 1.1rem;
            margin-top: 40px;
        }
    }
</style>
