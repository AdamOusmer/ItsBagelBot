---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/ui/PageHero.astro';
import LegalShell from '../components/legal/LegalShell.astro';

const sections = [
    { id: 'overview', heading: 'Overview', plain: 'What we collect, why, and what you can do about it.' },
    { id: 'data-collected', heading: 'Data We Collect', plain: 'Your Twitch handle, chat processed in the moment, anonymous usage stats.' },
    { id: 'data-not-collected', heading: "Data We Don't Collect", plain: 'No browsing history, no tracking IPs, no ad data. Ever.' },
    { id: 'cookies', heading: 'Cookies & Analytics', plain: 'No tracking cookies. Only strictly necessary security cookies.' },
    { id: 'data-use', heading: 'How We Use Your Data & Legal Basis', plain: 'To run the bot based on your consent and contract. Nothing is sold, rented, or shared.' },
    { id: 'payment-processing', heading: 'Third-Party Processors', plain: 'We use Tebex to securely handle checkout and payments. They act as the merchant of record.' },
    { id: 'storage', heading: 'Data Storage & Transfers', plain: 'Chat is processed live, not kept. Settings are encrypted in Canada.' },
    { id: 'rights', heading: 'Your Rights (GDPR, PIPEDA, Law 25)', plain: 'Ask for your data, portability, or its deletion any time.' },
    { id: 'changes', heading: 'Changes', plain: "If this policy changes meaningfully, you'll hear about it." },
    { id: 'contact', heading: 'Contact & Data Protection Officer', plain: 'Privacy questions go to support@itsbagelbot.com.' },
];
---

<Layout title="Privacy Policy — ItsBagelBot" description="ItsBagelBot privacy policy. Learn how we handle your data with transparency and respect.">
    <PageHero eyebrow="Legal" title="Privacy Policy" description="The full text, with a plain-words note on every section." />

    <LegalShell updated="July 2026" sections={sections}>
        <Fragment slot="overview">
            <p>
                ItsBagelBot is committed to protecting your privacy in accordance with GDPR (Europe), PIPEDA (Canada), and Law 25 (Quebec). This policy explains what data we collect,
                how we use it, and your rights.
            </p>
        </Fragment>

        <Fragment slot="data-collected">
            <p>We collect only what's necessary to provide the service:</p>
            <ul>
                <li>Twitch account information (username, channel ID) provided during OAuth connection</li>
                <li>Chat messages processed in real-time for moderation (not stored permanently)</li>
                <li>Usage analytics (aggregated, anonymized, no PII)</li>
            </ul>
        </Fragment>

        <Fragment slot="data-not-collected">
            <p>We never collect:</p>
            <ul>
                <li>Personal browsing data</li>
                <li>IP addresses for tracking</li>
                <li>Information from third-party trackers</li>
                <li>Data for advertising purposes</li>
            </ul>
        </Fragment>

        <Fragment slot="cookies">
            <p>
                We use Cloudflare Web Analytics for performance monitoring. Cloudflare's analytics are privacy-first and <strong>do not use cookies</strong> or store any client-side state. We do not use cookie banners because we do not use tracking or profiling cookies. Cloudflare may place strictly necessary security cookies (like <code>__cf_bm</code>) to protect against bots and DDoS attacks, which do not require consent.
            </p>
        </Fragment>

        <Fragment slot="data-use">
            <p>
                Solely to provide the ItsBagelBot service: moderate chat, execute commands, and run engagement
                features. Our legal basis for processing this data is the fulfillment of our contract with you (Terms of Service) and our legitimate interest in securing our service. We do not sell, rent, or share your data with third parties.
            </p>
        </Fragment>

        <Fragment slot="payment-processing">
            <p>
                To offer premium subscriptions, we integrate with Tebex. Tebex acts as the merchant of record for all transactions. When you initiate a checkout, we create a secure basket and redirect you to Tebex to complete the purchase. We do not process, collect, or store any payment details (like credit card numbers). We only receive the transaction ID and order status to fulfill your subscription. Tebex processes your payment data subject to their own Privacy Policy.
            </p>
        </Fragment>

        <Fragment slot="storage">
            <p>
                Chat messages are processed in real-time and not permanently stored. Configuration data is
                encrypted at rest. All data transit uses TLS 1.3 encryption. Your data is stored and processed securely in Canada, which benefits from an adequacy decision by the European Commission under the GDPR.
            </p>
        </Fragment>

        <Fragment slot="rights">
            <p>
                Under GDPR, Law 25, and PIPEDA, you have the right to access, rectify, port, or erase your personal data. 
                You can request data export or deletion at any time by contacting
                <a href="mailto:support@itsbagelbot.com">support@itsbagelbot.com</a>. Deleting your account
                removes all associated data immediately.
            </p>
        </Fragment>

        <Fragment slot="changes">
            <p>
                We may update this policy. Significant changes will be communicated via Discord and dashboard
                notifications.
            </p>
        </Fragment>

        <Fragment slot="contact">
            <p>
                For questions about privacy, or to reach our designated Data Protection Officer (Person in charge of personal information under Law 25), email
                <a href="mailto:support@itsbagelbot.com">support@itsbagelbot.com</a>.
            </p>
        </Fragment>
    </LegalShell>
</Layout>
